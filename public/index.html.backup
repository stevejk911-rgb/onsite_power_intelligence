/* ============================================================
   HELPERS
   ============================================================ */
function $(id){return document.getElementById(id);}
function num(id){var v=parseFloat($(id).value);return isFinite(v)?v:0;}
function pad(n){return n<10?"0"+n:""+n;}
function fmtDate(d){return d.getFullYear()+"-"+pad(d.getMonth()+1)+"-"+pad(d.getDate());}
function addMonths(d,n){return new Date(d.getFullYear(),d.getMonth()+Math.round(n),d.getDate());}
var MON=["Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"];
function monthYear(d){return MON[d.getMonth()]+" "+d.getFullYear();}
function monthsFromNow(str){
  if(!str) return 999;
  var t=new Date(str+"T00:00:00"), now=new Date();
  return (t.getFullYear()-now.getFullYear())*12 + (t.getMonth()-now.getMonth());
}
function fmtMoney(M){
  if(M>=1000) return "$"+(M/1000).toFixed(2)+"B";
  return "$"+Math.round(M)+"M";
}
function fmtAcres(a){
  if(a>=1000) return Math.round(a).toLocaleString()+" ac ("+(a/640).toFixed(1)+" sq mi)";
  if(a>=100) return Math.round(a).toLocaleString()+" ac";
  return a.toFixed(1)+" ac";
}
function fmtCO2(t){
  if(t<=0) return "~0 (on-site)";
  if(t>=1e6) return (t/1e6).toFixed(2)+" Mt/yr";
  return Math.round(t/1000).toLocaleString()+"k t/yr";
}
function normLowerBetter(vals){
  var mn=Math.min.apply(null,vals), mx=Math.max.apply(null,vals);
  return vals.map(function(v){return mx===mn?1:(mx-v)/(mx-mn);});
}
function acresToRadius(a){return Math.sqrt((a*4046.8564)/Math.PI);} // metres

/* ============================================================
   ASSUMPTIONS PANEL — built from DEFAULTS, read live from DOM
   ============================================================ */
function buildAssumptions(){
  var h='';
  h+='<div class="sec-title" style="margin-top:4px">Demand</div>';
  h+='<div class="agrid">';
  h+=afield("a_pue","PUE","total ÷ IT power",DEFAULTS.pue,0.01);
  h+=afield("a_reserve","Reserve margin","spare capacity, e.g. 0.15",DEFAULTS.reserve,0.05);
  h+=afield("a_util","Utilization","firm-source duty cycle",DEFAULTS.util,0.01);
  h+=afield("a_pipeCost","Gas lateral cost","$M per mile",DEFAULTS.pipeCost,0.5);
  h+='</div>';

  h+='<div class="sec-title">Per technology</div>';
  h+='<table class="atable"><thead><tr>'+
     '<th>Technology</th><th>Lead time<br>(months)</th><th>Capex<br>($/kW)</th>'+
     '<th>Footprint<br>(acres/MW)</th><th>Emissions<br>(tCO₂/MWh)</th></tr></thead><tbody>';
  KEYS.forEach(function(k){
    h+='<tr><td class="tname"><span class="dot" style="background:'+TECH[k].color+
       ';display:inline-block;width:9px;height:9px;border-radius:2px;margin-right:6px"></span>'+TECH[k].short+'</td>';
    h+='<td><input type="number" id="a_lead_'+k+'" value="'+DEFAULTS.lead[k]+'" step="1" min="1"></td>';
    h+='<td><input type="number" id="a_capex_'+k+'" value="'+DEFAULTS.capex[k]+'" step="50" min="1"></td>';
    h+='<td><input type="number" id="a_foot_'+k+'" value="'+DEFAULTS.foot[k]+'" step="0.01" min="0.001"></td>';
    h+='<td><input type="number" id="a_emis_'+k+'" value="'+DEFAULTS.emis[k]+'" step="0.05" min="0"'+
       (k==="solar"?" disabled":"")+'></td></tr>';
  });
  h+='</tbody></table>';

  h+='<div class="sec-title">Solar + BESS sizing</div>';
  h+='<div class="agrid">';
  h+=afield("a_solarCF","Solar capacity factor","avg output ÷ nameplate",DEFAULTS.solarCF,0.01);
  h+=afield("a_storageHrs","Storage duration","hours of battery to firm load",DEFAULTS.storageHrs,1);
  h+=afield("a_bessEnergyCost","BESS energy cost","$/kWh — battery pack (duration scales)",DEFAULTS.bessEnergyCost,5);
  h+=afield("a_bessPowerCost","BESS power cost","$/kW — BOS, inverter, fixed",DEFAULTS.bessPowerCost,10);
  h+='</div>';
  h+='<button class="resetbtn" id="resetA" type="button">Reset to defaults</button>';
  $("assumpBody").innerHTML=h;
  $("resetA").addEventListener("click",resetAssumptions);
  bindAssumptionInputs();
}
function afield(id,name,sub,val,step){
  return '<label>'+name+'<small>'+sub+'</small>'+
    '<input type="number" id="'+id+'" value="'+val+'" step="'+step+'"></label>';
}
function bindAssumptionInputs(){
  var ids=["a_pue","a_reserve","a_util","a_pipeCost","a_solarCF","a_storageHrs",
           "a_bessEnergyCost","a_bessPowerCost"];
  KEYS.forEach(function(k){ids.push("a_lead_"+k,"a_capex_"+k,"a_foot_"+k,"a_emis_"+k);});
  ids.forEach(function(id){var el=$(id);if(el)el.addEventListener("input",recompute);});
}
function resetAssumptions(){
  $("a_pue").value=DEFAULTS.pue; $("a_reserve").value=DEFAULTS.reserve;
  $("a_util").value=DEFAULTS.util; $("a_pipeCost").value=DEFAULTS.pipeCost;
  $("a_solarCF").value=DEFAULTS.solarCF; $("a_storageHrs").value=DEFAULTS.storageHrs;
  $("a_bessEnergyCost").value=DEFAULTS.bessEnergyCost;
  $("a_bessPowerCost").value=DEFAULTS.bessPowerCost;
  KEYS.forEach(function(k){
    $("a_lead_"+k).value=DEFAULTS.lead[k];
    $("a_capex_"+k).value=DEFAULTS.capex[k];
    $("a_foot_"+k).value=DEFAULTS.foot[k];
    $("a_emis_"+k).value=DEFAULTS.emis[k];
  });
  recompute();
}
function readA(){
  var A={pue:num("a_pue"),reserve:num("a_reserve"),util:num("a_util"),
    pipeCost:num("a_pipeCost"),solarCF:num("a_solarCF")||0.24,
    storageHrs:num("a_storageHrs"),
    bessEnergyCost:num("a_bessEnergyCost"),
    bessPowerCost:num("a_bessPowerCost"),
    lead:{},capex:{},foot:{},emis:{}};
  KEYS.forEach(function(k){
    A.lead[k]=num("a_lead_"+k); A.capex[k]=num("a_capex_"+k);
    A.foot[k]=num("a_foot_"+k); A.emis[k]=(k==="solar")?0:num("a_emis_"+k);
  });
  return A;
}

/* ============================================================
   FEASIBILITY ENGINE
   ============================================================ */
function compute(){
  var A=readA();
  var itload=num("itload");
  var pipe=num("pipe"), gridwait=num("gridwait"), land=num("land");
  var m2t=monthsFromNow($("target").value);
  var prio=document.querySelector('input[name="prio"]:checked').value;
  var W=WEIGHTS[prio];

  var facilityMW=itload*A.pue;                 // average electrical load to serve
  var designMW=facilityMW*(1+A.reserve);       // firm plant capacity incl. reserve

  // Hot zone capex uplift — 매칭된 sub-region이 있으면 capex_mul 적용
  // 매칭 안 되면 1.0 (baseline 그대로). techHardNo는 추천 시나리오에서 제외.
  var capexMul = currentHotZone ? currentHotZone.capexMul : 1.0;
  var hardNoTech = (currentHotZone && currentHotZone.techHardNo) ? currentHotZone.techHardNo : [];

  var res=KEYS.map(function(k){
    var t=TECH[k], r={key:k,t:t,notes:[],flags:[]};
    if(k==="solar"){
      r.capMW=A.solarCF>0?facilityMW/A.solarCF:0;          // DC nameplate to firm the load
      r.bessMWh=facilityMW*A.storageHrs;
      r.landAcres=r.capMW*A.foot[k];
      // BESS capex split formula — NREL/TP-6A40-93281 (Cole·Ramasamy·Turan 2025 update):
      //   Total ($/kW) = Energy Cost ($/kWh) × Duration + Power Cost ($/kW)
      // y=240.8x+379.16 (R²=0.9999) — battery pack은 duration scales, BOS는 fixed.
      // BESS 시스템은 facilityMW(부하 MW)로 sized; energy storage = facilityMW × storageHrs MWh.
      r.bessCapexM = (r.bessMWh * A.bessEnergyCost + facilityMW * A.bessPowerCost) / 1000;
      r.solarCapexM = r.capMW*A.capex[k]*capexMul/1000;     // PV 부분 단독 추적
      r.capexM = r.solarCapexM + r.bessCapexM;
      r.annualCO2=0;
      r.lateralMonths=0; r.lateralCost=0;
      r.leadTotal=A.lead[k];
      r.capLabel="Nameplate";
      r.notes.push("Sized to firm a 24/7 load: "+Math.round(r.capMW).toLocaleString()+
        " MW-DC + "+Math.round(r.bessMWh).toLocaleString()+" MWh battery. "+
        "내역: 솔라 "+fmtMoney(r.solarCapexM)+" + BESS "+fmtMoney(r.bessCapexM)+".");
      // BESS duration caveat — NREL Augustine & Blair 2021 SFS는 BESS modeling을 *10hr으로 cap*.
      // 그 이상은 extrapolation. 그리고 *어떤 duration이라도* solar+BESS만으로는 24/7 firm load 약속 못함.
      r.notes.push("⚠ Solar+BESS는 *24/7 firm을 약속 못함* — 1-2일 연속 흐림 ride-through 불가. "+
        "실제 hyperscaler는 *off-site PPA (annual matching)* + on-site gas/fuel cell (firm) 혼합 사용. "+
        "Microsoft 40 GW + Google 22 GW PPA 모두 off-site.");
      if(A.storageHrs > 10){
        r.notes.push("⚠ BESS "+A.storageHrs+"hr는 NREL modeled domain 밖 (Augustine & Blair 2021 SFS: BESS modeling capped at 10hr). "+
          "10hr 이상은 *extrapolation* — 정확도 떨어짐.");
      }
    }else{
      r.capMW=designMW;
      r.landAcres=r.capMW*A.foot[k];
      r.lateralMonths=0; r.lateralCost=0;
      if(t.fuel==="gas" && pipe>0.5){
        r.lateralMonths=Math.min(3+pipe*0.5,24);
        r.lateralCost=pipe*A.pipeCost;
      }
      r.capexM=r.capMW*A.capex[k]*capexMul/1000 + r.lateralCost;
      r.leadTotal=A.lead[k]+r.lateralMonths;
      r.annualCO2=r.capMW*8760*A.util*A.emis[k];
      r.capLabel="Plant capacity";
      if(r.lateralMonths>0)
        r.notes.push("Includes "+pipe+" mi gas lateral (+"+Math.round(r.lateralMonths)+
          " mo, +"+fmtMoney(r.lateralCost)+").");
    }
    // Hot zone capex uplift 표기 (사용자에게 가시화)
    if(currentHotZone && capexMul !== 1.0){
      r.notes.push(currentHotZone.short+" hot zone: capex ×"+capexMul+" applied.");
    }
    // techHardNo: 시나리오는 계산하되 flag 추가하여 ranking 페널티 적용
    if(hardNoTech.indexOf(k) >= 0){
      r.flags.push({t:currentHotZone.short+"에서 사실상 비추천 (환경 규제·시장 구조)", sev:"bad"});
      r.hardNo = true;
    }
    return r;
  });

  // relative scoring (lower is better for every metric)
  var sp=normLowerBetter(res.map(function(r){return r.leadTotal;}));
  var co=normLowerBetter(res.map(function(r){return r.capexM;}));
  var la=normLowerBetter(res.map(function(r){return r.landAcres;}));
  var ca=normLowerBetter(res.map(function(r){return r.annualCO2;}));

  res.forEach(function(r,i){
    r.sub={speed:sp[i]*100,cost:co[i]*100,land:la[i]*100,carbon:ca[i]*100};
    r.score=W.speed*r.sub.speed+W.cost*r.sub.cost+W.land*r.sub.land+W.carbon*r.sub.carbon;
    r.landFit=r.landAcres<=land && land>0;
    r.meetsDeadline=r.leadTotal<=m2t;
    r.onlineDate=addMonths(new Date(),r.leadTotal);
    if(!r.landFit) r.flags.push({t:"Exceeds the "+land+"-acre land budget",sev:"bad"});
    if(!r.meetsDeadline) r.flags.push({t:"Misses the target online date",sev:"warn"});
    if(r.t.fuel==="gas" && pipe>20)
      r.flags.push({t:"Gas tie-in is "+pipe+" mi away — major schedule & cost risk",sev:"warn"});
    if(r.key==="solar")
      r.flags.push({t:"Solar alone cannot firm a 24/7 load — needs heavy overbuild + storage",sev:"warn"});
    if(r.landFit && r.meetsDeadline)
      r.flags.push({t:"Fits the land and hits the schedule",sev:"good"});
    // Hot zone hardNo (Silicon Valley·Quincy WA의 gas turbine·recip 등)는 *land 초과보다 더 강한* 페널티.
    // -1500 = Solar의 land 초과(-1000)보다 낮음 → hardNo 시나리오는 ranking 최하위로 밀려남.
    r.rankScore=r.score-(r.landFit?0:1000)-(r.meetsDeadline?0:60)-(r.hardNo?1500:0);
  });

  // ============================================================
  // 하이브리드 시나리오 계산 (Phase 1 MVP, 2026-05-29)
  // 단일 4 시나리오와 *같은 yardstick*으로 합쳐 정규화 → Priya 갭 해소
  // ============================================================
  var hybrids = PRESET_HYBRIDS.map(function(h){
    var partials = {}, hardNoConflict = false, hasGas = false;
    var totalCapexM = 0, totalLandAcres = 0, totalCO2 = 0, totalCapMW = 0, bessTotalMWh = 0;
    var maxLead = 0;

    Object.keys(h.mix).forEach(function(k){
      var ratio = h.mix[k];
      var t = TECH[k], partial = { ratio: ratio };

      if(k === "solar"){
        var partialFacilityMW = facilityMW * ratio;
        partial.capMW = A.solarCF > 0 ? partialFacilityMW / A.solarCF : 0;
        partial.bessMWh = partialFacilityMW * A.storageHrs;
        partial.land = partial.capMW * A.foot[k];
        partial.capex = (partial.capMW * A.capex[k] * capexMul
                       + partial.bessMWh * A.bessEnergyCost
                       + partial.capMW * A.bessPowerCost) / 1000;
        partial.co2 = 0;
        bessTotalMWh += partial.bessMWh;
      } else {
        var partialDesignMW = designMW * ratio;
        partial.capMW = partialDesignMW;
        partial.land = partialDesignMW * A.foot[k];
        partial.capex = partialDesignMW * A.capex[k] * capexMul / 1000;
        partial.co2 = partialDesignMW * 8760 * A.util * A.emis[k];
        if(t.fuel === "gas") hasGas = true;
      }
      partial.lead = A.lead[k];

      partials[k] = partial;
      totalCapexM += partial.capex;
      totalLandAcres += partial.land;
      totalCO2 += partial.co2;
      totalCapMW += partial.capMW;
      if(partial.lead > maxLead) maxLead = partial.lead;
      if(hardNoTech.indexOf(k) >= 0) hardNoConflict = true;
    });

    // Gas lateral — gas-using 부분이 있으면 한 번만
    var lateralMonths = 0, lateralCost = 0;
    if(hasGas && pipe > 0.5){
      lateralMonths = Math.min(3 + pipe * 0.5, 24);
      lateralCost = pipe * A.pipeCost;
    }
    totalCapexM += lateralCost;

    var r = {
      key: "hybrid_" + h.id,
      h: h,
      isHybrid: true,
      t: { name: h.name, short: h.short, color: h.color, fuel: hasGas ? "gas" : "none" },
      partials: partials,
      capMW: totalCapMW,
      bessMWh: bessTotalMWh,
      capexM: totalCapexM,
      landAcres: totalLandAcres,
      annualCO2: totalCO2,
      leadTotal: maxLead + lateralMonths,
      lateralMonths: lateralMonths,
      lateralCost: lateralCost,
      hardNo: hardNoConflict,
      notes: [],
      flags: [],
      capLabel: "Mixed capacity"
    };

    // Notes
    var mixStr = Object.keys(h.mix).map(function(k){
      return TECH[k].short + " " + Math.round(h.mix[k] * 100) + "%";
    }).join(" + ");
    r.notes.push("구성: " + mixStr + ". 참고: " + h.ref_case);
    if(lateralMonths > 0){
      r.notes.push("Gas lateral " + pipe + " mi (+" + Math.round(lateralMonths) + " mo, +"
                   + fmtMoney(lateralCost) + ") — gas 부분 공유.");
    }
    if(hardNoConflict && currentHotZone){
      var hardNoNames = hardNoTech.filter(function(k){return h.mix[k];})
        .map(function(k){return TECH[k].short;}).join(", ");
      r.flags.push({t: currentHotZone.short + "에서 " + hardNoNames + " 비추천 — 하이브리드 mix 부적합", sev: "bad"});
    }
    return r;
  });

  // 단일 + 하이브리드 통합 — 같은 정규화 pool
  var allRes = res.concat(hybrids);

  // 통합 normalization (lead/cost/land/carbon 같은 yardstick)
  var allLeads = allRes.map(function(r){return r.leadTotal;});
  var allCosts = allRes.map(function(r){return r.capexM;});
  var allLands = allRes.map(function(r){return r.landAcres;});
  var allCarbons = allRes.map(function(r){return r.annualCO2;});
  var nSp = normLowerBetter(allLeads);
  var nCo = normLowerBetter(allCosts);
  var nLa = normLowerBetter(allLands);
  var nCa = normLowerBetter(allCarbons);

  // 하이브리드만 score·landFit·flags 처리 (단일은 위에서 이미 처리됨)
  hybrids.forEach(function(r, i){
    var idx = res.length + i;  // allRes에서의 인덱스
    r.sub = {
      speed: nSp[idx] * 100,
      cost: nCo[idx] * 100,
      land: nLa[idx] * 100,
      carbon: nCa[idx] * 100
    };
    r.score = W.speed*r.sub.speed + W.cost*r.sub.cost + W.land*r.sub.land + W.carbon*r.sub.carbon;
    r.landFit = r.landAcres <= land && land > 0;
    r.meetsDeadline = r.leadTotal <= m2t;
    r.onlineDate = addMonths(new Date(), r.leadTotal);
    if(!r.landFit) r.flags.push({t: "Exceeds the " + land + "-acre land budget", sev: "bad"});
    if(!r.meetsDeadline) r.flags.push({t: "Misses the target online date", sev: "warn"});
    if(r.t.fuel === "gas" && pipe > 20)
      r.flags.push({t: "Gas tie-in is " + pipe + " mi away — major schedule & cost risk", sev: "warn"});
    if(r.landFit && r.meetsDeadline && !r.hardNo)
      r.flags.push({t: "Fits the land and hits the schedule (hybrid mix)", sev: "good"});
    r.rankScore = r.score - (r.landFit?0:1000) - (r.meetsDeadline?0:60) - (r.hardNo?1500:0);
  });

  // 단일도 통합 normalize에 맞춰 재계산 (정확한 같은 yardstick)
  res.forEach(function(r, i){
    r.sub = {
      speed: nSp[i] * 100,
      cost: nCo[i] * 100,
      land: nLa[i] * 100,
      carbon: nCa[i] * 100
    };
    r.score = W.speed*r.sub.speed + W.cost*r.sub.cost + W.land*r.sub.land + W.carbon*r.sub.carbon;
    r.rankScore = r.score - (r.landFit?0:1000) - (r.meetsDeadline?0:60) - (r.hardNo?1500:0);
  });

  var ranked = allRes.slice().sort(function(a,b){return b.rankScore - a.rankScore;});
  ranked.forEach(function(r,i){r.rank = i+1;});

  return {res:res, hybrids:hybrids, allRes:allRes, ranked:ranked, rec:ranked[0],
          gridwait:gridwait, m2t:m2t, land:land, itload:itload,
          facilityMW:facilityMW, designMW:designMW, prio:prio};
}

/* ============================================================
   RENDER
   ============================================================ */
/* Print 전용 헤더·푸터 갱신 — recompute 시 자동 호출.
   화면에서는 display:none, @media print에서 표시. */
function updatePrintHeaderFooter(D){
  var hdr = $("workbenchPrintHeader"), ftr = $("workbenchPrintFooter");
  if(!hdr || !ftr) return;
  var today = new Date().toISOString().slice(0,10);
  var place = currentPlace || "(사이트 미지정)";
  var coords = currentLat != null && currentLng != null
    ? currentLat.toFixed(4) + ", " + currentLng.toFixed(4) : "";
  var region = (REGIONS[currentRegion] || {}).label || currentRegion || "";
  var zone = currentHotZone ? " · " + currentHotZone.short + " hot zone" : "";
  var itload = num("itload") || "—";
  var prio = (document.querySelector('input[name="prio"]:checked') || {}).value || "speed";
  var prioLabel = ({speed:"Speed first", balanced:"Balanced", carbon:"Low carbon"})[prio] || prio;

  hdr.innerHTML =
    '<h1>On-Site Power Intelligence — 단일 사이트 분석</h1>'+
    '<div class="meta">'+
      '<b>'+escapeAttr(place)+'</b>'+
      (coords ? ' · '+coords : '')+
      ' · '+escapeAttr(region)+zone+
      ' · '+itload+' MW IT load · priority: '+prioLabel+
      ' · 생성: '+today+
    '</div>';

  ftr.innerHTML =
    '<div><b>데이터 출처 + 신뢰도</b>: 우리 도구는 18+ verified source · 10 hot zones · 5 deployment cases 기반. '+
      'EIA-860 · NREL ATB · SEC EDGAR (Bloom, GE Vernova, Talen, Constellation, Vistra) · GridLab/EFG/Halcyon IRP filings · Bloom 10-K Item 1 직접 인용.</div>'+
    '<div style="margin-top:5px"><b>전체 데이터 자산 dashboard</b>: '+
      window.location.origin+'/data-sources.html '+
      '· <b>정직성 정정 이력</b>: 4번 (Talen-AWS · BESS storageHrs 12→6 · BESS split 공식 · Fuel cell lead 12→18)</div>'+
    '<div style="margin-top:5px;font-style:italic">본 자료는 *behind-the-meter 타당성 추정치*. '+
      '엔지니어링 study 아님. ±40% 정확도 가정. utility·OEM·EPC 견적으로 검증 후 의사결정.</div>';

  // Compare view용도 같이 갱신
  var chdr = $("comparePrintHeader"), cftr = $("comparePrintFooter");
  if(chdr){
    var siteCount = Object.keys(appState.sites || {}).length;
    chdr.innerHTML =
      '<h1>On-Site Power Intelligence — '+siteCount+' 사이트 비교</h1>'+
      '<div class="meta">생성: '+today+' · 같은 yardstick·hot zone 매핑·정직성 4번 정정 검증된 모델</div>';
  }
  if(cftr) cftr.innerHTML = ftr.innerHTML;
}

function recompute(){
  var itl=num("itload");
  if(itl<=0){
    $("inputwarn").style.display="block";
    $("inputwarn").textContent="Enter a target IT load greater than 0 MW to run the analysis.";
    return;
  }
  $("inputwarn").style.display="none";
  var D=compute();
  renderVerdict(D);
  renderNextSteps(D);
  renderCards(D);
  renderTable(D);
  drawFootprintSVG(D);
  drawMap(D);
  updatePrintHeaderFooter(D);    // print 전용 header/footer 갱신
  // sync the current site's state to localStorage on every recompute
  if(typeof appState !== "undefined" && appState.currentId) persistCurrentSite();
}

/* Turn the recommendation into a concrete week-1 contact list. This is the
 * "what do I do Monday morning" piece — it directly serves the target user
 * (data center developers, hyperscaler infra strategists) by closing the gap
 * between the verdict and action. */
function renderNextSteps(D){
  var box=$("nextsteps"); if(!box) return;
  var rec=D.rec;
  if(!rec || !rec.landFit){ box.innerHTML=""; box.style.display="none"; return; }
  box.style.display="";
  var R=REGIONS[currentRegion]||{};
  /* OEM 명단 — 2026-05-29 vendor 검증 기반.
     Aero GT (Solar Turbines Titan/PGM, Siemens SGT-A, GE Vernova LM)와 industrial frame을 분리.
     Recip은 Wartsila 282 MW Ohio 거래 검증 기반 우선순위 조정. */
  var oems={
    turbine: "Solar Turbines (CAT) Titan 250 또는 PGM 130 mobile, Siemens Energy SGT400/SGT-A, GE Vernova LM2500/LM6000 — 단 GE LM은 FY2024 orders 44/sales 27 공급 제약. Industrial frame H-class는 36-48mo lead, 데이터센터 BTM에 큼.",
    recip:   "Wärtsilä 18V50SG (Ohio 282 MW Q2'25 거래 검증, 18-21mo), Caterpillar 3520 (Meta Socrates 15대 검증), INNIO Jenbacher",
    fuelcell:"Bloom Energy SOFC ('less than 12 months booking-to-revenue' 10-K 인용), FuelCell Energy MCFC (Bridgeport·Derby CT 사이트 검증)",
    solar:   "regional utility-scale solar EPCs + BESS integrators (Tesla Megapack, Fluence, Wartsila Storage)"
  };
  var h='<h3>Next steps — turn this into this week’s email list</h3><ol>';
  h+='<li><b>Serving utility — written load-interconnection estimate.</b> Ask for a timeline and '+
     'substation-headroom assessment for a '+Math.round(rec.capMW).toLocaleString()+' MW load at '+
     '<i>'+(currentPlace||"this site")+'</i>. The '+(R.iso||"regional")+' typical is '+
     (R.gridWait||60)+' months — the real number only comes from them. 단, Meta Socrates처럼 *physically not connected* BTM도 옵션 (OPSB 2025-06-09 승인).</li>';
  if(rec.t.fuel==="gas"){
    h+='<li><b>Pipeline operator — capacity &amp; pressure.</b> Confirm deliverable gas volume and '+
       'pressure at the site. Distance ('+num("pipe")+' mi) is a proxy — what binds is whether the '+
       'line has capacity for this load. Meta Socrates는 24인치 파이프 2개.</li>';
  }
  h+='<li><b>OEM budgetary quotes.</b> Get order-of-magnitude pricing and current delivery slots from '+
     oems[rec.key]+'. The '+Math.round(rec.leadTotal)+'-month default은 권위 데이터 기반 (Bloom 10-K, Wartsila Q2\'25, GridLab 2025-09 IRP filings) — 실제 backlog는 vendor별로 빠르게 변동. ' +
     (rec.key === "turbine" ? "*GE Vernova는 KU/LG&E에 $25M reservation fee 요구* (2030 인도 슬롯 — KY PSC 2025-00045) — Tier 1 OEM은 슬롯 자체에 fee 발생 가능." : "") + '</li>';
  if(rec.t.fuel==="gas"){
    h+='<li><b>State air agency — permitting feasibility.</b> Pre-check air-emissions permitting for '+
       Math.round(rec.capMW)+' MW of '+rec.t.short+' at this site — nonattainment status, BACT/LAER '+
       'expectations, modeling needs.</li>';
  }else{
    h+='<li><b>Land &amp; off-take feasibility.</b> Verify the parcel is large enough and zoned for '+
       'utility-scale solar, and scope a PPA or self-supply structure for the BESS.</li>';
  }
  h+='</ol><div class="why">These are the four numbers the tool cannot give you — and they move the '+
     'recommendation more than anything else. The point of this screen is to shrink your week-1 '+
     'contact list to exactly this.</div>';
  box.innerHTML=h;
}

function renderVerdict(D){
  var rec=D.rec, v=$("verdict");
  var anyFit=D.ranked.some(function(r){return r.landFit;});
  var html="";
  if(!anyFit){
    var smallest=D.res.slice().sort(function(a,b){return a.landAcres-b.landAcres;})[0];
    html='<div class="vk">No option fits the land budget</div>'+
      '<h2>None of the four options fit within '+D.land+' acres</h2>'+
      '<p>The smallest footprint is '+smallest.t.name+' at '+fmtAcres(smallest.landAcres)+
      '. Increase the available land, reduce the IT load, or phase the build to make on-site viable.</p>';
  }else{
    var saved=D.gridwait-rec.leadTotal;
    var speedLine = saved>0
      ? "That is roughly <b>"+Math.round(saved)+" months ahead</b> of waiting out a "+D.gridwait+
        "-month grid interconnection queue — power is the schedule, and this is the faster path to it."
      : "A "+D.gridwait+"-month grid queue would not be slower than this — re-check the queue estimate, "+
        "because on-site only wins when it beats the queue.";
    html='<div class="vk">Fastest feasible path to power · priority: '+
      ({speed:"Speed first",balanced:"Balanced",carbon:"Low carbon"}[D.prio])+'</div>'+
      '<h2>'+rec.t.name+' — first power in ~'+Math.round(rec.leadTotal)+' months</h2>'+
      '<p>'+speedLine+(rec.meetsDeadline?"":" Note: this still misses your stated target date — the target may be unrealistic for any option.")+'</p>'+
      '<div class="stats">'+
        stat(Math.round(rec.leadTotal)+" mo","Time to power")+
        stat(monthYear(rec.onlineDate),"Earliest online")+
        stat(fmtMoney(rec.capexM),"Est. capex")+
        stat(fmtAcres(rec.landAcres),"Land needed")+
        stat(fmtCO2(rec.annualCO2),"Operating CO₂")+
      '</div>';

    // 조건부 nuclear caveat: carbon priority + 부하 > 300 MW일 때만 표시 (인지 부하 회피)
    // 우리 도구는 4 발전원만 계산하나, GW급 carbon-free 부하는 nuclear PPA가 진짜 competitor
    if(D.prio === "carbon" && num("itload") >= 300){
      html += '<div class="nuclear-caveat">'+
        '💡 <b>비교 옵션 — off-site nuclear PPA</b> (본 도구 범위 밖). '+
        'Microsoft TMI/CCEC 835 MW · Vistra Comanche 1,200 MW · Talen-AWS 1,920 MW 모두 *grid-connected FTM PPA*로 carbon-free 24/7 firm. '+
        '*BTM nuclear는 FERC 2024-11 거부 후 사실상 막힘*. GW급 carbon-free 부하라면 본 도구 4 시나리오와 *함께 비교 권장*.'+
        '</div>';
    }
  }
  v.innerHTML=html;
}
function stat(n,l){return '<div><div class="n">'+n+'</div><div class="l">'+l+'</div></div>';}

function renderCards(D){
  // 단일 시나리오만 메인 cards 영역에 표시 (4개)
  var c=$("cards"); c.innerHTML="";
  var singles = D.ranked.filter(function(r){ return !r.isHybrid; });
  singles.forEach(function(r){
    var el=document.createElement("div");
    el.className="card"+(r.rank===1&&r.landFit&&!r.hardNo?" rec":"")+(r.hardNo?" hardno":"");
    el.style.borderTopColor=r.t.color;
    var h="";
    // hardNo 카드는 RECOMMENDED 배지 표시 안 함 (CSS ::before가 비추천 배지 대체)
    if(r.rank===1&&r.landFit&&!r.hardNo) h+='<div class="recpill">Recommended</div>';
    h+='<div class="rank">#'+r.rank+'</div>';
    h+='<h3>'+r.t.name+'</h3>';
    // Lead time — ASSUMPTION_PROVENANCE['lead.'+key] tooltip 추가
    var leadProv = ASSUMPTION_PROVENANCE["lead."+r.key];
    h+='<div class="ttp">'+Math.round(r.leadTotal)+' <small>months</small>'+
       (leadProv?provBadge(leadProv,"lead"):'')+'</div>';
    h+='<div class="online">Online ~ '+monthYear(r.onlineDate)+'</div>';
    h+=metric(r.capLabel,Math.round(r.capMW).toLocaleString()+" MW");
    // Capex — ASSUMPTION_PROVENANCE['capex.'+key] tooltip 추가
    var capexProv = ASSUMPTION_PROVENANCE["capex."+r.key];
    h+=metric("Est. capex",fmtMoney(r.capexM)+(capexProv?provBadge(capexProv,"capex"):''));
    h+=metric("Land needed",fmtAcres(r.landAcres));
    h+=metric("Land fit",r.landFit
        ?'<span class="yes">fits</span>'
        :'<span class="no">over by '+fmtAcres(r.landAcres-D.land)+'</span>');
    h+=metric("Operating CO₂",fmtCO2(r.annualCO2));
    h+='<div class="scorebar"><i style="width:'+Math.max(2,r.score).toFixed(0)+
       '%;background:'+r.t.color+'"></i></div>';
    h+='<div class="scorelbl"><span>Fit score</span><span>'+Math.round(r.score)+' / 100</span></div>';
    h+='<div class="flags">';
    r.flags.forEach(function(f){h+='<div class="flag '+f.sev+'">'+f.t+'</div>';});
    h+='</div>';
    r.notes.forEach(function(n){h+='<div class="note">'+n+'</div>';});
    // Fleet context footer — EIA-860 2024 권위 fleet 데이터
    // 인지 부하 감소: #1 카드만 full 표시, 나머지 카드는 *한 줄 미니 요약*만
    var fc = FLEET_CONTEXT[r.key];
    if(fc){
      var isTopCard = (r.rank===1 && r.landFit && !r.hardNo);
      if(isTopCard){
        // 추천 #1 카드: full fleet context
        h+='<div class="fleetctx">'+
           '<div class="fleetctx-lbl">시장 컨텍스트 — EIA-860 2024</div>'+
           '<div class="fleetctx-row"><span>미국 fleet</span><b>'+fc.us_fleet_label+'</b></div>'+
           '<div class="fleetctx-row"><span>BTM 적합 사이즈</span><b>'+fc.btm_fit_label+'</b></div>'+
           '<div class="fleetctx-row"><span>2024 신규 BOL</span><b>'+
              (fc.bol_2024_MW != null ? fc.bol_2024_MW.toLocaleString()+" MW" : "—")+'</b></div>'+
           '<div class="fleetctx-row"><span>최대 운영자</span><b>'+fc.top_operator+'</b></div>'+
           '<div class="fleetctx-growth">'+fc.growth_signal+'</div>'+
           '</div>';
      } else {
        // 다른 카드: 한 줄 미니 요약만 (시장 비교용)
        h+='<div class="fleetctx-mini">시장: '+fc.us_fleet_label+' · BTM 적합 '+fc.btm_fit_label+'</div>';
      }
    }
    el.innerHTML=h;
    c.appendChild(el);
  });

  // 하이브리드 카드 별도 그리드
  renderHybridCards(D);
  // Nuclear PPA 비교 섹션 (David 5번째 시나리오)
  renderNuclearPPATable(D);
}

/* renderNuclearPPATable — 3 verified nuclear PPA deals를 표 형식으로 비교.
   사용자 IT load 기준으로 equivalent fit 자동 표시. */
function renderNuclearPPATable(D){
  var c = $("nuclearPPATable"); if(!c) return;
  var userLoad = D.itload || 0;
  var h = '<table class="nuclear-ppa-table">'+
    '<thead><tr>'+
      '<th>Deal</th>'+
      '<th>Capacity</th>'+
      '<th>Term</th>'+
      '<th>Structure</th>'+
      '<th>ISO·State</th>'+
      '<th>Online</th>'+
      '<th>당신 부하 fit</th>'+
      '<th>Significance</th>'+
    '</tr></thead><tbody>';

  PRESET_NUCLEAR_PPAS.forEach(function(p){
    // Fit 평가: 사용자 IT load 대비 PPA capacity
    var fitPct = userLoad > 0 ? Math.round(userLoad / p.capacity_MW * 100) : 0;
    var fitClass, fitLabel;
    if(fitPct < 30){
      fitClass = "fit-small";
      fitLabel = fitPct + "% — 너무 큼";
    } else if(fitPct <= 90){
      fitClass = "fit-good";
      fitLabel = fitPct + "% — 적합";
    } else if(fitPct <= 130){
      fitClass = "fit-tight";
      fitLabel = fitPct + "% — 추가 PPA 필요";
    } else {
      fitClass = "fit-over";
      fitLabel = fitPct + "% — 다중 PPA";
    }

    var termStr = p.term_years + "yr" + (p.extension_years ? " + " + p.extension_years + "opt" : "");
    var dollarStr = p.USD_billion ? "$" + p.USD_billion + "B" : "비공개";
    var rampStr = p.full_ramp_year && p.online_year && p.full_ramp_year > p.online_year
      ? p.online_year + "→" + p.full_ramp_year : p.online_year;

    h += '<tr>'+
      '<td class="deal"><a href="'+p.ref_url+'" target="_blank" rel="noopener" '+
        'style="color:#1f2937;text-decoration:none;font-weight:600">'+p.short+
        ' <span style="color:#7c3aed">↗</span></a>'+
        '<div class="dealsub">'+p.name+'</div></td>'+
      '<td><b>'+p.capacity_MW.toLocaleString()+' MW</b><div class="dealsub">'+dollarStr+'</div></td>'+
      '<td>'+termStr+'</td>'+
      '<td><div style="font-size:11px">'+p.structure+'</div></td>'+
      '<td>'+p.ISO+'<div class="dealsub">'+p.state+'</div></td>'+
      '<td>'+rampStr+'</td>'+
      '<td class="'+fitClass+'">'+fitLabel+'</td>'+
      '<td><div style="font-size:11px;color:#475569">'+p.significance+'</div></td>'+
      '</tr>';
  });

  h += '</tbody></table>';

  // 사용자 부하 기준 권장 framing
  if(userLoad >= 800){
    h += '<div class="nuclear-ppa-rec">💡 <b>당신의 '+userLoad+' MW 부하</b>는 *GW급 nuclear PPA 후보*. '+
         'BTM 시나리오와 nuclear PPA 둘 다 IC 메모·CEO 슬라이드에 포함 권장. '+
         '*Talen restructured 패턴 (BTM 시도 → FTM 전환)*에 주의.</div>';
  } else if(userLoad >= 200){
    h += '<div class="nuclear-ppa-rec">💡 <b>당신의 '+userLoad+' MW 부하</b>는 *nuclear PPA 단독 너무 큼*. '+
         'BTM이 적합. Nuclear는 *다중 사이트 portfolio* 차원에서만 비교.</div>';
  }

  c.innerHTML = h;
}

/* renderHybridCards — 3 verified hybrid 시나리오 (Phase 1 MVP).
   단일 카드와 같은 yardstick으로 정규화된 결과를 별도 섹션에 표시. */
function renderHybridCards(D){
  var c=$("hybridCards"); if(!c) return;
  c.innerHTML="";
  var hybrids = D.ranked.filter(function(r){ return r.isHybrid; });
  hybrids.forEach(function(r){
    var el=document.createElement("div");
    el.className="card hybrid-card"
      +(r.rank===1&&r.landFit&&!r.hardNo?" rec":"")
      +(r.hardNo?" hardno":"");
    el.style.borderTopColor=r.t.color;
    var h="";
    if(r.rank===1&&r.landFit&&!r.hardNo) h+='<div class="recpill">Recommended</div>';
    h+='<div class="rank">#'+r.rank+' (전체 7 중)</div>';
    h+='<h3>'+r.t.name+'</h3>';
    // Mix breakdown 시각화 (각 발전원 비율 bar)
    h+='<div class="mixbar">';
    Object.keys(r.h.mix).forEach(function(k){
      var pct = Math.round(r.h.mix[k] * 100);
      h+='<span class="mixseg" style="background:'+TECH[k].color+';width:'+pct+'%" title="'+
        TECH[k].short+' '+pct+'%">'+pct+'%</span>';
    });
    h+='</div>';
    h+='<div class="mixlbl">';
    Object.keys(r.h.mix).forEach(function(k){
      h+='<span><span class="dot" style="background:'+TECH[k].color+'"></span>'+TECH[k].short+'</span>';
    });
    h+='</div>';
    h+='<div class="ttp">'+Math.round(r.leadTotal)+' <small>months</small></div>';
    h+='<div class="online">Online ~ '+monthYear(r.onlineDate)+'</div>';
    h+=metric(r.capLabel,Math.round(r.capMW).toLocaleString()+" MW");
    h+=metric("Est. capex",fmtMoney(r.capexM));
    h+=metric("Land needed",fmtAcres(r.landAcres));
    h+=metric("Land fit",r.landFit
        ?'<span class="yes">fits</span>'
        :'<span class="no">over by '+fmtAcres(r.landAcres-D.land)+'</span>');
    h+=metric("Operating CO₂",fmtCO2(r.annualCO2));
    h+='<div class="scorebar"><i style="width:'+Math.max(2,r.score).toFixed(0)+
       '%;background:'+r.t.color+'"></i></div>';
    h+='<div class="scorelbl"><span>Fit score</span><span>'+Math.round(r.score)+' / 100</span></div>';
    h+='<div class="flags">';
    r.flags.forEach(function(f){h+='<div class="flag '+f.sev+'">'+f.t+'</div>';});
    h+='</div>';
    r.notes.forEach(function(n){h+='<div class="note">'+n+'</div>';});
    el.innerHTML=h;
    c.appendChild(el);
  });
}

function metric(k,v){return '<div class="metric"><span class="k">'+k+'</span><span class="v">'+v+'</span></div>';}

/* provBadge — value 옆 (i) 배지 + custom HTML popup.
   - Hover (desktop) / click·Enter (mobile/keyboard) 둘 다 작동
   - 출처 URL 직접 link
   - a11y: role=button, aria-expanded, aria-describedby, keyboard focus·ESC */
var _provIdCounter = 0;
function provBadge(prov, kind){
  if(!prov) return '';
  var confColor = prov.confidence === "high" ? "#16a34a"
    : prov.confidence === "medium" ? "#eab308"
    : "#dc2626";
  var confLabel = prov.confidence === "high" ? "높음 (verified)"
    : prov.confidence === "medium" ? "중간 (partial)"
    : "낮음 (estimate)";
  var rangeStr = prov.range ? prov.range[0]+'–'+prov.range[1]+' '+prov.unit : "";
  var id = "prov_" + (++_provIdCounter);
  var popupId = id + "_pop";
  var srcLink = prov.url
    ? '<a href="'+escapeAttr(prov.url)+'" target="_blank" rel="noopener noreferrer" class="prov-srclink">출처 열기 ↗</a>'
    : '';
  // Popup HTML — display:none initial, JS toggles on hover/click
  var popup =
    '<div class="provpop" id="'+popupId+'" role="tooltip" aria-hidden="true">'+
      '<div class="prov-conf"><span class="prov-confdot" style="background:'+confColor+'"></span>'+
      '신뢰도: <b>'+escapeAttr(confLabel)+'</b>'+
      (rangeStr ? ' · 범위 '+escapeAttr(rangeStr) : '')+'</div>'+
      '<div class="prov-src">'+escapeAttr(prov.source || '(출처 미명시)')+'</div>'+
      (prov.note ? '<div class="prov-note">'+escapeAttr(prov.note)+'</div>' : '')+
      (srcLink ? '<div class="prov-link">'+srcLink+'</div>' : '')+
    '</div>';
  // Badge (i) — tabbable button, popup 위치 absolute
  return '<span class="provwrap">'+
    '<button type="button" class="provbadge" '+
      'aria-label="이 값의 출처·신뢰도 보기 — 신뢰도 '+escapeAttr(confLabel)+'" '+
      'aria-expanded="false" aria-describedby="'+popupId+'" '+
      'style="background:'+confColor+'" '+
      'onclick="toggleProvPopup(this, event)" '+
      'onkeydown="if(event.key===\'Escape\'){closeAllProvPopups();this.blur();}">i</button>'+
    popup+
  '</span>';
}

function escapeAttr(s){
  return String(s == null ? "" : s)
    .replace(/&/g,"&amp;").replace(/"/g,"&quot;")
    .replace(/</g,"&lt;").replace(/>/g,"&gt;");
}

/* Popup toggle — 다른 popup 모두 닫고 이거만 열기. */
function toggleProvPopup(btn, ev){
  if(ev) ev.stopPropagation();
  var pop = btn.parentNode.querySelector(".provpop");
  var isOpen = pop.classList.contains("open");
  closeAllProvPopups();
  if(!isOpen){
    pop.classList.add("open");
    pop.setAttribute("aria-hidden", "false");
    btn.setAttribute("aria-expanded", "true");
  }
}
function closeAllProvPopups(){
  document.querySelectorAll(".provpop.open").forEach(function(p){
    p.classList.remove("open");
    p.setAttribute("aria-hidden", "true");
    var btn = p.parentNode.querySelector(".provbadge");
    if(btn) btn.setAttribute("aria-expanded", "false");
  });
}
// 외부 click·ESC로 popup 닫기 (global listener — 한 번만 등록)
if(!window._provGlobalBound){
  window._provGlobalBound = true;
  document.addEventListener("click", function(e){
    if(!e.target.closest(".provwrap")) closeAllProvPopups();
  });
  document.addEventListener("keydown", function(e){
    if(e.key === "Escape") closeAllProvPopups();
  });
}

function renderTable(D){
  // Phase 1 MVP: 단일 + 하이브리드 모두 한 표에 (같은 yardstick)
  var rows = D.allRes || D.res;
  var h='<thead><tr><th>Technology</th><th>Time to power</th><th>Online</th>'+
    '<th>Capex</th><th>Land</th><th>Fits land</th><th>CO₂ / yr</th><th>Score</th></tr></thead><tbody>';
  rows.forEach(function(r){
    h+='<tr><td class="tname"><span class="dot" style="background:'+r.t.color+'"></span>'+r.t.short+'</td>'+
      '<td>'+Math.round(r.leadTotal)+' mo</td>'+
      '<td>'+monthYear(r.onlineDate)+'</td>'+
      '<td>'+fmtMoney(r.capexM)+'</td>'+
      '<td>'+fmtAcres(r.landAcres)+'</td>'+
      '<td>'+(r.landFit?'<span class="yes">yes</span>':'<span class="no">no</span>')+'</td>'+
      '<td>'+fmtCO2(r.annualCO2)+'</td>'+
      '<td>'+Math.round(r.score)+'</td></tr>';
  });
  h+='</tbody>';
  $("cmp").innerHTML=h;
}

/* ============================================================
   MAP
   ============================================================ */
var map, siteMarker, siteLL={lat:39.0438,lng:-77.4874}, mapLayers=[];
var lg={}, infraData=null, needRefit=true, solarInfo=null;
var currentRegion="PJM", currentPlace="", currentStateNote="", regionAuto=true;
var currentLat=null, currentLng=null;  // hot zone 매칭용 — setSite에서 매번 갱신

function mapFallback(){
  map=null;
  ["maplegend","maptools"].forEach(function(id){var e=$(id); if(e) e.style.display="none";});
  $("map").innerHTML='<div class="mapmsg">The interactive map needs a web browser with internet — '+
    'open this file in Chrome or Safari to see it, with real transmission, substation and pipeline '+
    'layers. The land-footprint diagram below works everywhere, and the full analysis is unaffected.</div>';
}
function initMap(){
  if(typeof L==="undefined"){ mapFallback(); return; }
  try{
    map=L.map("map",{scrollWheelZoom:true}).setView([39.5,-96],4);
    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png",{
      maxZoom:19,
      attribution:'© OpenStreetMap contributors'
    }).addTo(map);

    var pinIcon=L.divIcon({className:"",html:
      '<div style="width:20px;height:20px;border-radius:50% 50% 50% 0;'+
      'background:#0f172a;border:3px solid #f59e0b;transform:rotate(-45deg);'+
      'box-shadow:0 2px 6px rgba(0,0,0,.4)"></div>',
      iconSize:[20,20],iconAnchor:[10,18]});

    siteMarker=L.marker([siteLL.lat,siteLL.lng],{draggable:true,icon:pinIcon}).addTo(map);
    siteMarker.on("dragend",function(){
      var p=siteMarker.getLatLng(); setSite(p.lat,p.lng,false);   // don't refit on drag
    });
    map.on("click",function(e){ setSite(e.latlng.lat,e.latlng.lng,false); }); // don't refit on click

    lg.trans=L.layerGroup(); lg.sub=L.layerGroup();
    lg.plant=L.layerGroup(); lg.pipe=L.layerGroup();
    renderLegend();
  }catch(err){
    mapFallback();
  }
}

/* Move the site, then auto-detect region and load nearby infrastructure. */
function setSite(lat,lng,refit){
  siteLL={lat:lat,lng:lng};
  currentLat = lat; currentLng = lng;   // hot zone 매칭 state 갱신
  if(siteMarker) siteMarker.setLatLng([lat,lng]);
  if(refit!==false) needRefit=true;   // default true; click/drag pass false to preserve the view
  updateLatLng();
  // 좌표 박스 자동 동기화 (사용자 요청 2026-05-29) — 어떤 액션이든 (preset·지명검색·맵클릭·드래그·좌표입력)
  if($("coord")) $("coord").value = lat.toFixed(4) + ", " + lng.toFixed(4);
  recompute();              // instant visual update
  detectRegion(lat,lng);    // async: refine region + grid/gas defaults + addr 박스 동기화
  fetchInfra(lat,lng);      // async: load real OSM power infrastructure
  fetchSolar(lat,lng);      // async: site-specific solar capacity factor (NREL)
}
function updateLatLng(){
  $("latlng").textContent="Site: "+siteLL.lat.toFixed(4)+", "+siteLL.lng.toFixed(4)+
    "  ·  drag the pin to adjust";
}
function clearMapLayers(){
  mapLayers.forEach(function(l){map.removeLayer(l);});
  mapLayers=[];
}
var INFRA_BBOX=0.10;   // degrees around the site to search / frame (~10 km)

function drawMap(D){
  if(!map) return;                       // app preview / no Leaflet -> static message stands
  clearMapLayers();
  var c=[siteLL.lat,siteLL.lng];
  var bb=L.latLngBounds([siteLL.lat-INFRA_BBOX,siteLL.lng-INFRA_BBOX],
                        [siteLL.lat+INFRA_BBOX,siteLL.lng+INFRA_BBOX]);
  // gas tie-in ring (user input — a distance, direction unknown)
  if($("gasring").checked){
    var pipe=num("pipe");
    if(pipe>0){
      var gr=L.circle(c,{radius:pipe*1609.34,color:"#b45309",weight:2,
        dashArray:"4 6",fill:false});
      gr.bindTooltip("Gas tie-in distance ≈ "+pipe+" mi (your input — direction unknown)",{sticky:true});
      gr.addTo(map); mapLayers.push(gr); bb.extend(gr.getBounds());
    }
  }
  if(needRefit){ map.fitBounds(bb,{padding:[28,28],maxZoom:14}); needRefit=false; }
}
function renderLegend(){
  if(!$("maplegend")) return;
  var rows=[
    ['<span class="swatch" style="background:#0f172a;border:2px solid #f59e0b"></span>','Data center site'],
    ['<span class="swatch line" style="border-top:3px solid #dc2626"></span>','Transmission line'],
    ['<span class="swatch" style="background:#2563eb;border-radius:50%"></span>','Substation'],
    ['<span class="swatch" style="background:#7c3aed;border-radius:50%"></span>','Power plant'],
    ['<span class="swatch line" style="border-top:3px dashed #c2410c"></span>','Gas pipeline'],
    ['<span class="swatch line" style="border-top:3px dashed #b45309"></span>','Gas tie-in ring']
  ];
  var h='<div style="font-weight:700;margin-bottom:3px">Map legend</div>';
  rows.forEach(function(r){ h+='<div class="lg">'+r[0]+r[1]+'</div>'; });
  $("maplegend").innerHTML=h;
}

/* ============================================================
   REAL INFRASTRUCTURE LAYERS — OpenStreetMap via the Overpass API
   Community-sourced data: good for US transmission & substations,
   patchier for gas pipelines. Browser + internet only.
   ============================================================ */
function setLayerStatus(m){ var e=$("layerStatus"); if(e) e.textContent=m; }

function fetchInfra(lat,lng){
  if(!map) return;
  if(typeof fetch==="undefined"){ setLayerStatus("Map layers need a browser with internet."); return; }
  var thisId = (typeof appState !== "undefined" ? appState.currentId : null);
  setLayerStatus("Loading nearby infrastructure…");
  fetch("/api/infra?lat="+lat+"&lon="+lng)
  .then(function(r){ if(!r.ok) throw new Error("HTTP "+r.status); return r.json(); })
  .then(function(j){
    if(thisId !== appState.currentId) return;             // stale — user switched site
    if(j && j.error) throw new Error(j.error);
    infraData=parseInfra((j&&j.elements)||[]); drawInfraLayers();
  })
  .catch(function(){
    if(thisId !== appState.currentId) return;
    var msg = infraData
      ? "Layer fetch failed — showing the previous successful result for this area."
      : "Couldn't load infrastructure layers from the server.";
    var el = $("layerStatus");
    if(el){
      el.innerHTML = escapeHtml(msg) +
        ' <a href="#" id="retryInfra" style="color:#dc2626;font-weight:600">Retry ↻</a>';
      var r = $("retryInfra");
      if(r) r.addEventListener("click", function(e){
        e.preventDefault();
        fetchInfra(lat, lng);
      });
    }
  });
}
/* Site-specific solar capacity factor from NREL PVWatts (via the backend). */
function fetchSolar(lat,lng){
  if(typeof fetch==="undefined") return;
  var thisId = (typeof appState !== "undefined" ? appState.currentId : null);
  fetch("/api/solar?lat="+lat+"&lon="+lng)
  .then(function(r){ return r.json(); })
  .then(function(d){
    if(thisId !== appState.currentId) return;             // stale — user switched site
    if(d && typeof d.capacityFactor==="number" && d.capacityFactor>0){
      solarInfo={cf:d.capacityFactor, src:d.source||"NREL PVWatts"};
      var el=$("a_solarCF"); if(el) el.value=d.capacityFactor.toFixed(3);
      renderRegionContext(false);
      recompute();
    }
  })
  .catch(function(){});
}
function parseInfra(els){
  var out={trans:[],sub:[],plant:[],pipe:[]};
  els.forEach(function(el){
    var t=el.tags||{};
    if(el.type==="way" && el.geometry && el.geometry.length){
      var pts=el.geometry.map(function(g){return [g.lat,g.lon];});
      if(t.power==="line") out.trans.push({pts:pts,tags:t});
      else if(t.man_made==="pipeline") out.pipe.push({pts:pts,tags:t});
      else if(t.power==="substation") out.sub.push({ll:centroid(pts),tags:t});
      else if(t.power==="plant"||t.power==="generator") out.plant.push({ll:centroid(pts),tags:t});
    }else if(el.type==="node" && isFinite(el.lat)){
      if(t.power==="substation") out.sub.push({ll:[el.lat,el.lon],tags:t});
      else if(t.power==="plant"||t.power==="generator") out.plant.push({ll:[el.lat,el.lon],tags:t});
    }
  });
  return out;
}
function centroid(pts){
  var la=0,lo=0; pts.forEach(function(p){la+=p[0];lo+=p[1];});
  return [la/pts.length,lo/pts.length];
}
function voltTip(t){
  if(!t.voltage) return "";
  var v=parseInt((""+t.voltage).split(";")[0],10);
  return isFinite(v) ? " · "+(v>=1000?Math.round(v/1000)+" kV":v+" V") : "";
}
function drawInfraLayers(){
  if(!map||!infraData) return;
  ["trans","sub","plant","pipe"].forEach(function(k){ lg[k].clearLayers(); });
  infraData.trans.forEach(function(o){
    L.polyline(o.pts,{color:"#dc2626",weight:2,opacity:.85})
      .bindTooltip("Transmission line"+voltTip(o.tags),{sticky:true}).addTo(lg.trans);
  });
  infraData.pipe.forEach(function(o){
    L.polyline(o.pts,{color:"#c2410c",weight:2.5,opacity:.85,dashArray:"5 5"})
      .bindTooltip("Gas pipeline"+(o.tags.name?" · "+o.tags.name:
        (o.tags.operator?" · "+o.tags.operator:"")),{sticky:true}).addTo(lg.pipe);
  });
  infraData.sub.forEach(function(o){
    L.circleMarker(o.ll,{radius:5,color:"#1e3a8a",weight:1.5,fillColor:"#2563eb",fillOpacity:.9})
      .bindTooltip((o.tags.name||"Substation")+voltTip(o.tags),{sticky:true}).addTo(lg.sub);
  });
  infraData.plant.forEach(function(o){
    var src=o.tags["plant:source"]||o.tags["generator:source"]||o.tags.source||"";
    L.circleMarker(o.ll,{radius:6,color:"#5b21b6",weight:1.5,fillColor:"#7c3aed",fillOpacity:.9})
      .bindTooltip((o.tags.name||"Power plant")+(src?" · "+src:""),{sticky:true}).addTo(lg.plant);
  });
  applyLayerVisibility();
  var n=infraData, tot=n.trans.length+n.sub.length+n.plant.length+n.pipe.length;
  setLayerStatus(tot
    ? n.trans.length+" lines · "+n.sub.length+" substations · "+n.plant.length+" plants"+
      (n.pipe.length?" · "+n.pipe.length+" gas lines":"")
    : "No OSM-mapped infrastructure within ~10 km of this point.");
}
function applyLayerVisibility(){
  if(!map) return;
  [["lyrTrans","trans"],["lyrSub","sub"],["lyrPlant","plant"],["lyrPipe","pipe"]].forEach(function(p){
    var box=$(p[0]), grp=lg[p[1]];
    if(!box||!grp) return;
    if(box.checked){ if(!map.hasLayer(grp)) grp.addTo(map); }
    else if(map.hasLayer(grp)) map.removeLayer(grp);
  });
}

/* ============================================================
   OFFLINE FOOTPRINT DIAGRAM — dependency-free SVG fallback,
   used when the interactive Leaflet map cannot load
   ============================================================ */
function svgWrap(inner){
  return '<svg viewBox="0 0 600 560" width="100%" height="100%" '+
    'preserveAspectRatio="xMidYMid meet" '+
    'style="background:#f8fafc;border-radius:12px;font-family:inherit">'+inner+'</svg>';
}
function niceDistance(m){
  var mi=m/1609.34, nice=[0.05,0.1,0.25,0.5,1,2,5,10,25,50,100,200], pick=nice[0];
  for(var i=0;i<nice.length;i++){ if(nice[i]<=mi) pick=nice[i]; }
  return pick*1609.34;
}
function fmtDist(m){
  var mi=m/1609.34;
  return (mi<1?mi.toFixed(2):(""+Math.round(mi*10)/10))+" mi";
}
function drawFootprintSVG(D){
  var items=[];
  if(D.land>0) items.push({label:"Available land — "+fmtAcres(D.land),
    color:"#0d9488",metres:acresToRadius(D.land),kind:"land"});
  D.res.forEach(function(r){
    items.push({label:r.t.short+" — "+fmtAcres(r.landAcres),
      color:r.t.color,metres:acresToRadius(r.landAcres),kind:"fp"});
  });
  var cap='<text x="300" y="24" text-anchor="middle" fill="#475569" font-size="12">'+
    'Each ring = the land that option’s plant occupies, to scale</text>';
  if(items.length<2){
    $("fpDiagram").innerHTML=svgWrap(cap+'<text x="300" y="260" text-anchor="middle" '+
      'fill="#94a3b8" font-size="14">Enter an IT load and available land</text>');
    $("fpSide").innerHTML=""; return;
  }
  var maxM=Math.max.apply(null,items.map(function(x){return x.metres;}));
  var cx=300, cy=235, R=195, scale=R/maxM, inner=cap;
  items.slice().sort(function(a,b){return b.metres-a.metres;}).forEach(function(it){
    var pr=Math.max(it.metres*scale,1.3);
    var dash=(it.kind==="land")?' stroke-dasharray="7 5"':'';
    var fo=(it.kind==="fp")?0.16:0.06;
    inner+='<circle cx="'+cx+'" cy="'+cy+'" r="'+pr.toFixed(1)+'" fill="'+it.color+'" '+
      'fill-opacity="'+fo+'" stroke="'+it.color+'" stroke-width="2"'+dash+'>'+
      '<title>'+it.label+'</title></circle>';
  });
  inner+='<circle cx="'+cx+'" cy="'+cy+'" r="5" fill="#0f172a" stroke="#f59e0b" stroke-width="2.5"/>';
  var barM=Math.min(niceDistance(maxM/3),maxM), barPx=barM*scale, bx=44, by=455;
  inner+='<line x1="'+bx+'" y1="'+by+'" x2="'+(bx+barPx)+'" y2="'+by+'" stroke="#475569" stroke-width="2"/>'+
    '<line x1="'+bx+'" y1="'+(by-4)+'" x2="'+bx+'" y2="'+(by+4)+'" stroke="#475569" stroke-width="2"/>'+
    '<line x1="'+(bx+barPx)+'" y1="'+(by-4)+'" x2="'+(bx+barPx)+'" y2="'+(by+4)+'" stroke="#475569" stroke-width="2"/>'+
    '<text x="'+bx+'" y="'+(by-9)+'" fill="#475569" font-size="12">'+fmtDist(barM)+' radius</text>';
  var ly=482;
  items.forEach(function(it,i){
    var lx=44+(i%2)*278, yy=ly+Math.floor(i/2)*21;
    inner+='<rect x="'+lx+'" y="'+(yy-10)+'" width="13" height="13" rx="2" fill="'+it.color+'" '+
      'fill-opacity="'+(it.kind==="fp"?0.5:0.2)+'" stroke="'+it.color+'" stroke-width="1.5"/>'+
      '<text x="'+(lx+20)+'" y="'+yy+'" fill="#334155" font-size="12">'+it.label+'</text>';
  });
  $("fpDiagram").innerHTML=svgWrap(inner);
  var solar=D.res[3];
  var small=D.res.slice().sort(function(a,b){return a.landAcres-b.landAcres;})[0];
  var ratio=small.landAcres>0?Math.round(solar.landAcres/small.landAcres):0;
  $("fpSide").innerHTML=
    '<p><b>Why a separate panel.</b> On a geographic map these footprints are either an invisible '+
    'dot or they swallow the screen — so the area comparison lives here, at one controlled scale.</p>'+
    '<p>The gas-fired plants are tiny: '+small.t.short+' is smallest at '+fmtAcres(small.landAcres)+
    ', a corner of the site. Solar + BESS needs '+fmtAcres(solar.landAcres)+
    (ratio>1?' — about '+ratio+'× the smallest option':'')+', because it is sized to firm a 24/7 load.</p>'+
    '<p style="color:#64748b;font-size:12px">Dashed ring = your available land ('+fmtAcres(D.land)+'). '+
    'An option whose ring spills outside it does not fit.</p>';
}

/* ============================================================
   GEOCODING (Nominatim) — optional, fails gracefully
   ============================================================ */
/* 좌표 박스 값을 parse — valid한 lat,lng면 [lat,lng], 아니면 null. */
function parseCoordInput(){
  var raw = $("coord").value.trim();
  if(!raw) return null;
  var parts = raw.split(/[,\s]+/).filter(function(x){return x.length;});
  if(parts.length < 2) return null;
  var lat = parseFloat(parts[0]), lng = parseFloat(parts[1]);
  if(!isFinite(lat) || !isFinite(lng)) return null;
  if(lat < -90 || lat > 90 || lng < -180 || lng > 180) return null;
  return [lat, lng];
}

function geocode(){
  var q=$("addr").value.trim();
  // 충돌 처리 (사용자 요청 2026-05-29): 좌표 박스에 *유효한 좌표*가 있으면 좌표 우선
  // — Find 버튼 눌렀어도 coord가 있으면 그게 진실로 간주
  var coordParsed = parseCoordInput();
  if(coordParsed){
    $("latlng").textContent = "지명·좌표 둘 다 입력 — 좌표 우선 적용";
    gotoCoord();
    return;
  }
  if(!q) return;
  if(typeof fetch==="undefined"){
    $("latlng").textContent="Address search needs internet — paste coordinates or pick a hub instead.";
    return;
  }
  var btn=$("addrBtn"); btn.textContent="…";
  fetch("/api/geo?q="+encodeURIComponent(q))
    .then(function(r){return r.json();})
    .then(function(d){
      btn.textContent="Find";
      if(d&&d.length){
        setSite(parseFloat(d[0].lat),parseFloat(d[0].lon));
        // setSite 안에서 coord 박스가 자동 동기화됨
      }
      else $("latlng").textContent="No match found — paste coordinates or click the map instead.";
    })
    .catch(function(){
      btn.textContent="Find";
      $("latlng").textContent="Address search unavailable — paste coordinates or click the map instead.";
    });
}

/* Parse a pasted "lat, lng" string. */
function gotoCoord(){
  var parsed = parseCoordInput();
  if(parsed){
    setSite(parsed[0], parsed[1]);
    // setSite + detectRegion이 addr 박스를 reverse geocode 결과로 자동 채움
  }else{
    $("latlng").textContent="좌표 형식 인식 실패 — 예: 41.3947, -87.9486";
  }
}

/* Reverse-geocode the site -> US state -> grid region, then auto-fill defaults. */
function detectRegion(lat,lng){
  var coordLabel="Site at "+lat.toFixed(4)+", "+lng.toFixed(4);
  var thisId = (typeof appState !== "undefined" ? appState.currentId : null);
  if(typeof fetch==="undefined"){
    currentPlace=coordLabel; regionAuto=false; renderRegionContext(true); recompute(); return;
  }
  $("regionContext").innerHTML='<div class="rk">Regional context</div>'+
    '<p style="margin:6px 0 0;color:#64748b">Detecting grid region for this location…</p>';
  fetch("/api/geo?lat="+lat+"&lon="+lng)
    .then(function(r){return r.json();})
    .then(function(d){
      if(thisId !== appState.currentId) return;          // stale — user switched site
      var a=(d&&d.address)||{};
      if((a.country_code||"").toLowerCase()!=="us"){
        currentPlace=d&&d.display_name?d.display_name.split(",").slice(0,2).join(",").trim():"";
        // 지명 박스 자동 동기화 — non-US도 reverse 결과로 채움
        if($("addr") && currentPlace) $("addr").value = currentPlace;
        currentStateNote=""; regionAuto=false;
        renderRegionContext(true); recompute(); return;
      }
      var state=(a.state||"").toLowerCase();
      var county=a.county||a.city||a.town||a.municipality||"";
      var key=regionFromState(state,lat,lng);
      currentPlace=(county?county+", ":"")+(a.state||"United States");
      // 지명 박스 자동 동기화 (사용자 요청 2026-05-29) — 좌표 입력·맵 클릭·드래그 시 자동 채움
      if($("addr")) $("addr").value = currentPlace;
      currentStateNote=STATE_NOTES[state]||"";
      if(key){ regionAuto=true; applyRegion(key,true); }
      else { regionAuto=false; renderRegionContext(true); recompute(); }
    })
    .catch(function(){
      if(thisId !== appState.currentId) return;
      currentPlace=coordLabel; regionAuto=false; renderRegionContext(true); recompute();
    });
}
function regionFromState(state,lat,lng){
  if(state==="illinois") return lat>=40.7?"PJM":"MISO"; // northern IL (ComEd) is PJM
  return STATE_REGION[state]||null;
}

/* ============================================================
   DATA-CENTER HOT ZONE OVERLAY (sub-region uplift)
   ----------------------------------------------------------------
   ISO mapping(PJM/ERCOT/...)만으로는 NoVA vs Columbus 같은 차이를
   못 잡는다. Verified hot zone 5곳에 grid wait / gas distance / capex
   uplift를 매핑. 매칭되면 ISO baseline에 uplift 곱/덧셈.
   출처는 data/regions/data-center-hot-zones.json (full provenance).
   ============================================================ */
var HOT_ZONES = [
