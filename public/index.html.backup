<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>On-Site Power Intelligence — Behind-the-Meter Feasibility for AI Data Centers</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<style>
  :root{
    --bg:#eef1f4; --ink:#0f172a; --muted:#64748b; --line:#e2e8f0;
    --panel:#ffffff; --slate:#0f172a; --amber:#f59e0b; --teal:#0d9488;
    --turbine:#dc2626; --recip:#ea580c; --fuelcell:#7c3aed; --solar:#16a34a;
    --bad:#dc2626; --warn:#d97706; --good:#16a34a;
  }
  *{box-sizing:border-box}
  body{margin:0;background:var(--bg);color:var(--ink);
    font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    font-size:14px;line-height:1.5;}
  header{background:var(--slate);color:#fff;padding:20px 24px;}
  header h1{margin:0;font-size:20px;letter-spacing:-.01em;}
  header .tag{margin-top:6px;color:#94a3b8;font-size:13px;max-width:760px;}
  header .badge{display:inline-block;margin-top:10px;font-size:11px;color:#fcd34d;
    border:1px solid #475569;border-radius:999px;padding:3px 10px;}
  .wrap{max-width:1480px;margin:0 auto;padding:18px;}
  .topgrid{display:grid;grid-template-columns:392px 1fr;gap:16px;}
  .panel{background:var(--panel);border:1px solid var(--line);border-radius:12px;
    box-shadow:0 1px 2px rgba(15,23,42,.04);}
  .controls{padding:16px;max-height:560px;overflow:auto;}
  .sec-title{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.07em;
    color:var(--muted);margin:16px 0 8px;}
  .sec-title:first-child{margin-top:0;}
  label.fld{display:block;margin-bottom:10px;}
  label.fld span{display:block;font-size:12px;font-weight:600;color:#334155;margin-bottom:3px;}
  label.fld small{font-weight:400;color:var(--muted);}
  input[type=number],input[type=date],input[type=text],select{
    width:100%;padding:8px 10px;border:1px solid var(--line);border-radius:8px;
    font-size:14px;font-family:inherit;background:#fff;color:var(--ink);}
  input:focus,select:focus{outline:2px solid #93c5fd;outline-offset:0;border-color:#93c5fd;}
  /* regional context */
  .regionctx{margin-top:16px;background:#fff;border:1px solid var(--line);border-left:4px solid var(--teal);
    border-radius:12px;padding:14px 18px;}
  .regionctx .rk{font-size:11px;text-transform:uppercase;letter-spacing:.07em;color:var(--teal);font-weight:700;}
  .regionctx h3{margin:3px 0 6px;font-size:16px;}
  .regionctx p{margin:0 0 8px;color:#334155;}
  .regionctx .rgrid{display:flex;flex-wrap:wrap;gap:10px;margin:10px 0 4px;}
  .regionctx .rcell{background:#f8fafc;border:1px solid var(--line);border-radius:8px;
    padding:8px 12px;min-width:150px;}
  .regionctx .rcell .l{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;}
  .regionctx .rcell .n{font-size:15px;font-weight:700;}
  .regionctx .src{font-size:11px;color:var(--muted);margin-top:6px;}
  .row2{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
  .presets{display:flex;flex-wrap:wrap;gap:6px;}
  .presets button,.searchrow button{font:inherit;cursor:pointer;}
  .chip{background:#f1f5f9;border:1px solid var(--line);border-radius:999px;
    padding:5px 11px;font-size:12px;color:#334155;}
  .chip:hover{background:#e2e8f0;}
  .searchrow{display:flex;gap:6px;}
  .searchrow input{flex:1;}
  .searchrow button{background:var(--slate);color:#fff;border:none;border-radius:8px;padding:0 14px;}
  .latlng{font-size:12px;color:var(--muted);margin-top:6px;}
  .seg{display:flex;border:1px solid var(--line);border-radius:8px;overflow:hidden;}
  .seg label{flex:1;text-align:center;}
  .seg input{position:absolute;opacity:0;pointer-events:none;}
  .seg label span{display:block;padding:7px 4px;font-size:12px;font-weight:600;
    color:#475569;cursor:pointer;background:#fff;}
  .seg label input:checked+span{background:var(--slate);color:#fff;}
  /* map */
  .mapwrap{position:relative;overflow:hidden;}
  #map{height:560px;width:100%;border-radius:12px;background:#dde3e9;}
  .maptools{position:absolute;top:10px;right:10px;z-index:500;background:#fff;
    border:1px solid var(--line);border-radius:10px;padding:10px 12px;
    box-shadow:0 2px 8px rgba(15,23,42,.12);font-size:12px;width:214px;}
  .maptools b{font-size:11px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);}
  .maptools label{display:flex;align-items:center;gap:6px;margin-top:6px;cursor:pointer;}
  .mt-status{margin-top:9px;padding-top:8px;border-top:1px solid var(--line);
    font-size:11px;color:var(--muted);line-height:1.4;}
  .maplegend{position:absolute;bottom:12px;left:12px;z-index:500;background:rgba(255,255,255,.94);
    border:1px solid var(--line);border-radius:10px;padding:9px 11px;font-size:11px;
    box-shadow:0 2px 8px rgba(15,23,42,.12);}
  .maplegend .lg{display:flex;align-items:center;gap:6px;margin:3px 0;}
  .swatch{width:14px;height:14px;border-radius:3px;flex:none;}
  .swatch.line{height:0;width:16px;border-radius:0;}
  .mapmsg{display:flex;align-items:center;justify-content:center;height:100%;
    padding:28px;text-align:center;color:#475569;font-size:13px;line-height:1.65;}
  /* footprint-to-scale panel */
  .fppanel{margin-top:16px;padding:16px;}
  .fpbody{display:flex;gap:22px;align-items:center;flex-wrap:wrap;}
  #fpDiagram{flex:1.1;min-width:300px;max-width:540px;}
  .fpside{flex:1;min-width:240px;font-size:13px;color:#334155;}
  .fpside p{margin:0 0 8px;line-height:1.6;}
  .fpside b{color:var(--ink);}
  /* verdict */
  .verdict{margin-top:16px;border-radius:12px;padding:18px 20px;color:#fff;
    background:linear-gradient(120deg,#0f172a 0%,#7c2d12 60%,#b45309 100%);
    border:1px solid #1e293b;}
  .verdict .vk{font-size:11px;text-transform:uppercase;letter-spacing:.08em;color:#fcd34d;}
  .verdict h2{margin:4px 0 6px;font-size:21px;letter-spacing:-.01em;}
  .verdict p{margin:0;color:#e2e8f0;max-width:900px;}
  .verdict .stats{display:flex;flex-wrap:wrap;gap:22px;margin-top:14px;}
  .verdict .stats div{border-left:2px solid #f59e0b;padding-left:10px;}
  .verdict .stats .n{font-size:18px;font-weight:700;}
  .verdict .stats .l{font-size:11px;color:#cbd5e1;text-transform:uppercase;letter-spacing:.05em;}
  /* Nuclear PPA 비교 옵션 — carbon priority + 부하 >= 300 MW 조건부 표시 */
  .verdict .nuclear-caveat{
    margin-top:16px;padding:10px 12px;
    background:rgba(255,255,255,0.08);border-left:3px solid #fcd34d;
    border-radius:6px;font-size:12px;line-height:1.5;color:#fef3c7;
  }
  .verdict .nuclear-caveat b{color:#fff;}
  /* sitebar — multi-site portfolio strip */
  .sitebar{background:#fff;border:1px solid var(--line);border-radius:12px;padding:10px 12px;
    margin-bottom:16px;display:flex;gap:12px;align-items:center;flex-wrap:wrap;
    box-shadow:0 1px 2px rgba(15,23,42,.04);}
  .sb-label{font-size:10px;text-transform:uppercase;letter-spacing:.08em;color:var(--muted);
    font-weight:700;padding-right:8px;border-right:1px solid var(--line);}
  .site-tabs{display:flex;flex-wrap:wrap;gap:6px;flex:1;min-width:200px;}
  .site-chip{background:#f1f5f9;border:1px solid var(--line);border-radius:8px;
    padding:6px 11px;font:inherit;font-size:12.5px;cursor:pointer;color:#334155;
    display:flex;flex-direction:column;align-items:flex-start;gap:1px;line-height:1.25;}
  .site-chip:hover{background:#e2e8f0;}
  .site-chip.active{background:var(--slate);color:#fff;border-color:var(--slate);
    box-shadow:0 1px 3px rgba(15,23,42,.18);}
  .site-chip.active .site-chip-sub{color:#94a3b8;}
  .site-chip-name{font-weight:600;}
  .site-chip-sub{font-size:10.5px;color:var(--muted);}
  .sb-new{background:#fff;border:1px dashed #94a3b8;color:#475569;border-radius:8px;
    padding:6px 11px;font:inherit;font-size:12.5px;cursor:pointer;font-weight:600;}
  .sb-new:hover{background:#f8fafc;border-color:var(--slate);color:var(--slate);}
  .sb-actions{display:flex;gap:6px;align-items:center;}
  .sb-icon{background:transparent;border:1px solid var(--line);border-radius:6px;
    padding:5px 9px;font:inherit;font-size:11.5px;color:#475569;cursor:pointer;}
  .sb-icon:hover{background:#f1f5f9;}
  .sb-cta{background:var(--amber);border:none;border-radius:8px;padding:7px 14px;
    font:inherit;font-size:12.5px;font-weight:700;color:#1f2937;cursor:pointer;}
  .sb-cta:hover{background:#ea580c;color:#fff;}
  /* compare mode body toggle */
  body.mode-compare #workbench{display:none;}
  body:not(.mode-compare) #compareView{display:none;}
  /* compare view panel */
  .compareview{margin-top:0;padding:18px 20px;}
  .compareview .cv-head{display:flex;justify-content:space-between;align-items:baseline;
    margin-bottom:14px;gap:12px;flex-wrap:wrap;}
  .compareview h2{margin:0;font-size:18px;letter-spacing:-.01em;}
  .compareview .cv-sub{font-size:12.5px;color:var(--muted);}
  table.cmpSites{width:100%;border-collapse:collapse;font-size:13px;}
  table.cmpSites th,table.cmpSites td{text-align:right;padding:9px 10px;border-bottom:1px solid var(--line);
    white-space:nowrap;}
  table.cmpSites th:first-child,table.cmpSites td:first-child{text-align:left;}
  table.cmpSites thead th{font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);}
  table.cmpSites tbody tr{cursor:pointer;}
  table.cmpSites tbody tr:hover{background:#f8fafc;}
  table.cmpSites .sname{font-weight:700;}
  table.cmpSites .sname small{display:block;font-weight:400;color:var(--muted);font-size:11px;}
  table.cmpSites .dot{display:inline-block;width:9px;height:9px;border-radius:2px;margin-right:6px;}
  .cv-empty{padding:40px;text-align:center;color:var(--muted);font-size:13px;}
  /* next-steps action checklist */
  .nextsteps{margin-top:16px;padding:16px 20px;}
  .nextsteps h3{margin:0 0 10px;font-size:12px;text-transform:uppercase;letter-spacing:.06em;color:var(--muted);}
  .nextsteps ol{margin:0;padding-left:22px;}
  .nextsteps li{margin-bottom:9px;line-height:1.55;color:#334155;font-size:13.5px;}
  .nextsteps li b{color:var(--ink);}
  .nextsteps .why{font-size:12px;color:var(--muted);margin-top:10px;border-top:1px solid var(--line);padding-top:9px;}
  /* cards */
  .cards{margin-top:16px;display:grid;grid-template-columns:repeat(4,1fr);gap:12px;}
  .card{background:#fff;border:1px solid var(--line);border-radius:12px;padding:14px;
    border-top:4px solid #999;position:relative;}
  .card.rec{box-shadow:0 0 0 2px var(--amber);}
  .card .rank{position:absolute;top:12px;right:12px;font-size:11px;font-weight:700;
    color:var(--muted);background:#f1f5f9;border-radius:999px;padding:2px 8px;}
  .card .recpill{position:absolute;top:-11px;left:14px;background:var(--amber);color:#1f2937;
    font-size:10px;font-weight:800;text-transform:uppercase;letter-spacing:.06em;
    padding:3px 8px;border-radius:999px;}
  .card h3{margin:2px 0 2px;font-size:14px;}
  .card .ttp{font-size:30px;font-weight:800;letter-spacing:-.02em;line-height:1.1;}
  .card .ttp small{font-size:13px;font-weight:600;color:var(--muted);}
  .card .online{font-size:12px;color:var(--muted);margin-bottom:8px;}
  .metric{display:flex;justify-content:space-between;border-top:1px solid var(--line);
    padding:5px 0;font-size:12.5px;}
  .metric .k{color:var(--muted);}
  .metric .v{font-weight:600;text-align:right;}
  .scorebar{height:7px;background:#f1f5f9;border-radius:999px;margin-top:9px;overflow:hidden;}
  .scorebar i{display:block;height:100%;background:var(--slate);border-radius:999px;}
  .scorelbl{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);margin-top:4px;}
  .flags{margin-top:8px;display:flex;flex-direction:column;gap:4px;}
  .flag{font-size:11px;border-radius:6px;padding:4px 7px;line-height:1.35;font-weight:600;}
  .flag.bad{background:#fee2e2;color:#7f1d1d;border:1px solid #dc2626;}
  .flag.warn{background:#fffbeb;color:#92400e;border:1px solid #fde68a;}
  .flag.good{background:#f0fdf4;color:#166534;border:1px solid #bbf7d0;font-weight:500;}
  /* hardNo 카드 자체에 시각 신호 — opacity 살짝 줄이고 회색 빗금 효과 (사용자가 한 눈에 비추천 인지) */
  .card.hardno{opacity:0.7;background:repeating-linear-gradient(45deg,#fff,#fff 8px,#fafafa 8px,#fafafa 16px);}
  .card.hardno::before{
    content:"이 hot zone에서 사용 비추천";
    display:block;background:#dc2626;color:#fff;font-size:10px;font-weight:700;
    text-align:center;padding:3px 0;margin:-14px -14px 8px -14px;
    border-radius:8px 8px 0 0;
  }
  .note{font-size:11px;color:var(--muted);margin-top:8px;line-height:1.4;}

  /* ===== Print 버튼 + Print CSS (iter2 PDF export) ===== */
  .printbar{
    display:flex;align-items:center;gap:12px;
    margin-top:12px;padding:10px 14px;
    background:#fff;border:1px dashed var(--line);border-radius:8px;
  }
  .printbtn{
    background:var(--amber);color:#1f2937;font-weight:700;
    border:none;padding:8px 14px;border-radius:6px;cursor:pointer;
    font-size:13px;font-family:inherit;
  }
  .printbtn:hover{filter:brightness(1.05);}
  .printbtn:focus-visible{outline:2px solid #92400e;outline-offset:2px;}
  .printhint{color:var(--muted);font-size:12px;}

  /* Print 전용 헤더/푸터 — 화면에서는 숨김 */
  .printheader, .printfooter{display:none;}

  /* ===== @media print — PDF export 최적화 ===== */
  @media print {
    /* 기본 reset */
    @page { size: A4; margin: 12mm 14mm; }
    body, html { background: #fff !important; color: #000; font-size: 11pt; }
    -webkit-print-color-adjust: exact;
    print-color-adjust: exact;

    /* 숨길 요소 — 사용자 조작 UI */
    header.topbar, .sitebar, .siterow, .navmenu,
    .topbar, .toplinks, footer,
    .printbar, .printbtn, .printhint,
    #addrBtn, #coordBtn, #addrBox, #coordBox,
    #addr, #coord, .findbtn, .gobtn,
    .agroup, .preset, .resetbtn,
    button#closeCompareBtn,
    details > summary,  /* assumptions·method summary는 숨김 */
    .gasring, #regionLabel select, #region,
    .latlng, .source.src, .footnote {
      display: none !important;
    }
    /* assumptions·method 펼침 내용도 숨김 */
    details { display: none !important; }

    /* 지도는 인쇄에서 별로 가치 없음 (interactive) — 숨김 */
    #map, .maplegend, .maplayers, .layerctl,
    .leaflet-container, .leaflet-control-container { display: none !important; }

    /* 메인 panel들 크기 조정 */
    .panel { box-shadow: none !important; border: 1px solid #e5e7eb !important;
             margin: 8px 0 !important; padding: 10px 12px !important;
             break-inside: avoid; page-break-inside: avoid; }

    /* Verdict 박스 — 검은 배경 유지 (인쇄 색상 유지) */
    .verdict {
      background: #0f172a !important; color: #fff !important;
      padding: 14px 16px !important; border-radius: 8px;
      break-inside: avoid; page-break-inside: avoid;
    }
    .verdict h2 { font-size: 16pt; margin: 4px 0; }
    .verdict p { font-size: 10pt; color: #e2e8f0 !important; }
    .verdict .stats { gap: 14px; margin-top: 10px; }
    .verdict .stats .n { font-size: 12pt; }
    .verdict .stats .l { font-size: 8pt; }
    .verdict .nuclear-caveat { font-size: 9pt; }

    /* Regional context 패널 */
    .regionctx { background: #fff !important; padding: 10px !important; }
    .regionctx h3 { font-size: 12pt; }

    /* 결과 카드 — 4개를 한 페이지에 압축 */
    .cards {
      display: grid !important;
      grid-template-columns: 1fr 1fr !important;
      gap: 8px !important;
    }
    .card {
      border: 1px solid #e5e7eb !important;
      padding: 8px 10px !important;
      break-inside: avoid; page-break-inside: avoid;
      box-shadow: none !important;
    }
    .card h3 { font-size: 11pt; }
    .card .ttp { font-size: 18pt !important; }
    .card .online { font-size: 9pt; }
    .card .metric { font-size: 9pt; padding: 3px 0; }
    .card .note { font-size: 8pt; }
    .card.hardno { opacity: 1 !important; }  /* 회색 빗금 유지 위해 opacity 무시 */
    .recpill { font-size: 8pt; padding: 2px 6px; }

    /* Fleet context 박스 — 작게 표시 */
    .fleetctx { font-size: 8pt; padding: 5px 7px; }
    .fleetctx-mini { font-size: 8pt; }

    /* Provenance (i) 배지·popup 숨김 — 인쇄에서 hover 안 됨 */
    .provwrap, .provbadge, .provpop { display: none !important; }

    /* 비교 표 */
    table.cmp { font-size: 9pt; }
    table.cmp th, table.cmp td { padding: 4px 6px; }

    /* Compare view */
    .compareview { page-break-before: auto; }
    table.cmpSites { font-size: 9pt; }
    table.cmpSites th, table.cmpSites td { padding: 5px 7px; }

    /* Print 전용 헤더 — 도구 이름 + 날짜 + URL */
    .printheader {
      display: block !important;
      text-align: center;
      margin-bottom: 10px;
      padding-bottom: 8px;
      border-bottom: 2px solid #f59e0b;
    }
    .printheader h1 {
      font-size: 14pt; margin: 0 0 4px;
      letter-spacing: -0.01em;
    }
    .printheader .meta {
      font-size: 9pt; color: #64748b;
    }

    /* Print 전용 푸터 — 데이터 출처·dashboard URL */
    .printfooter {
      display: block !important;
      margin-top: 14px;
      padding: 8px 10px;
      border-top: 1px solid #e5e7eb;
      font-size: 8pt;
      color: #475569;
      line-height: 1.5;
      break-inside: avoid;
    }
    .printfooter b { color: #1f2937; }

    /* Next steps 체크리스트 — 인쇄에 핵심 */
    .nextsteps ol { font-size: 10pt; }
    .nextsteps li { margin: 4px 0; }

    /* Page break 컨트롤 */
    h2, h3 { break-after: avoid; page-break-after: avoid; }
    .verdict, .nextsteps, .cards, table.cmp { break-after: auto; }
  }

  /* 하이브리드 시나리오 섹션 (Phase 1 MVP, 2026-05-29) */
  .hybrid-section{
    margin-top:24px;padding:16px 18px;
    background:#f8fafc;border:1px solid var(--line);border-radius:10px;
  }
  .hybrid-title{font-size:14px;margin:0 0 4px;letter-spacing:-.01em;}
  .hybrid-sub{font-size:12px;color:var(--muted);margin:0 0 14px;line-height:1.5;}
  .hybrid-cards{margin-top:8px;}
  .hybrid-card{border-top-width:4px;}
  /* Mix breakdown bar — 발전원 비율 시각화 */
  .mixbar{
    display:flex;width:100%;height:18px;border-radius:4px;overflow:hidden;
    margin:8px 0 4px;background:#e5e7eb;
  }
  .mixseg{
    display:flex;align-items:center;justify-content:center;
    color:#fff;font-size:10px;font-weight:700;
    text-shadow:0 1px 2px rgba(0,0,0,0.3);
  }
  .mixlbl{
    display:flex;flex-wrap:wrap;gap:10px;font-size:10.5px;color:var(--muted);
    margin-bottom:6px;
  }
  .mixlbl span{display:inline-flex;align-items:center;gap:4px;}
  .mixlbl .dot{display:inline-block;width:9px;height:9px;border-radius:50%;}

  /* Nuclear PPA 5번째 시나리오 섹션 (David 갭) */
  .nuclear-ppa-section{
    margin-top:18px;padding:16px 18px;
    background:#fef9c3;border:1px solid #fde047;border-radius:10px;
  }
  .nuclear-ppa-title{font-size:14px;margin:0 0 4px;color:#713f12;letter-spacing:-.01em;}
  .nuclear-ppa-sub{font-size:12px;color:#78350f;margin:0 0 12px;line-height:1.5;}
  .nuclear-ppa-foot{font-size:11.5px;color:#78350f;margin:10px 0 0;line-height:1.5;
                    padding-top:10px;border-top:1px dashed #fde047;}
  table.nuclear-ppa-table{
    width:100%;border-collapse:collapse;font-size:11.5px;background:#fff;
    border-radius:6px;overflow:hidden;
  }
  table.nuclear-ppa-table th{
    background:#fef3c7;color:#78350f;font-size:10.5px;
    text-transform:uppercase;letter-spacing:.05em;
    text-align:left;padding:8px 10px;font-weight:600;
  }
  table.nuclear-ppa-table td{
    padding:8px 10px;border-top:1px solid #fef3c7;vertical-align:top;
  }
  table.nuclear-ppa-table td.deal{font-weight:600;color:#1f2937;}
  table.nuclear-ppa-table .dealsub{font-size:10px;color:var(--muted);margin-top:2px;}
  table.nuclear-ppa-table td.fit-good{color:#15803d;font-weight:600;}
  table.nuclear-ppa-table td.fit-small{color:#475569;}
  table.nuclear-ppa-table td.fit-tight{color:#92400e;font-weight:600;}
  table.nuclear-ppa-table td.fit-over{color:#7c2d12;font-weight:600;}
  .nuclear-ppa-rec{
    margin-top:12px;padding:9px 12px;
    background:rgba(255,255,255,0.7);border-left:3px solid #f59e0b;border-radius:4px;
    font-size:12px;color:#78350f;line-height:1.5;
  }
  .nuclear-ppa-rec b{color:#451a03;}

  /* Fleet context footer (EIA-860 권위 fleet 데이터 시각화) */
  .fleetctx{
    margin-top:10px;padding:8px 10px;
    background:#f8fafc;border:1px solid var(--line);border-radius:6px;
    font-size:10.5px;line-height:1.5;
  }
  .fleetctx-lbl{
    font-weight:700;color:#475569;
    text-transform:uppercase;letter-spacing:0.04em;
    font-size:9.5px;margin-bottom:4px;
  }
  .fleetctx-row{display:flex;justify-content:space-between;gap:8px;}
  .fleetctx-row span{color:var(--muted);}
  .fleetctx-row b{color:#1f2937;font-weight:600;text-align:right;}
  .fleetctx-growth{
    margin-top:5px;padding-top:5px;border-top:1px dashed var(--line);
    color:#475569;font-style:italic;font-size:10px;
  }
  /* 미니 요약: 추천 #1 외 카드용 — 한 줄, 인지 부하 최소 */
  .fleetctx-mini{
    margin-top:10px;padding:6px 10px;
    background:#f8fafc;border:1px solid var(--line);border-radius:6px;
    font-size:10.5px;color:#475569;line-height:1.4;
  }

  /* ===== Provenance badge + custom popup (Task #24 UX 강화) ===== */
  .provwrap{position:relative;display:inline-block;vertical-align:middle;margin-left:6px;}
  .provbadge{
    width:16px;height:16px;line-height:16px;
    border-radius:50%;color:#fff;font-size:10px;font-weight:700;
    text-align:center;padding:0;border:none;cursor:pointer;
    font-family:inherit;display:inline-block;vertical-align:middle;
  }
  .provbadge:focus-visible{outline:2px solid var(--amber);outline-offset:2px;}
  .provbadge:hover{filter:brightness(1.1);}
  /* Hover로도 popup 열림 (desktop) — 작은 화면에서는 click만 사용 */
  @media (hover:hover) and (pointer:fine){
    .provwrap:hover .provpop{display:block;}
  }
  .provpop{
    display:none;position:absolute;z-index:50;
    top:24px;right:0;width:300px;max-width:90vw;
    background:#fff;border:1px solid var(--line);border-radius:8px;
    padding:11px 13px;font-size:12px;line-height:1.5;
    box-shadow:0 8px 24px rgba(0,0,0,0.12);
    text-align:left;color:#1f2937;
  }
  .provpop.open{display:block;}
  .prov-conf{display:flex;align-items:center;gap:5px;font-size:11px;color:var(--muted);margin-bottom:6px;}
  .prov-confdot{display:inline-block;width:9px;height:9px;border-radius:50%;}
  .prov-src{font-weight:600;color:#111827;margin-bottom:6px;}
  .prov-note{color:#374151;margin-bottom:8px;font-size:11px;}
  .prov-link{margin-top:4px;}
  .prov-srclink{
    display:inline-block;font-size:11px;color:var(--amber);
    text-decoration:underline;font-weight:600;
  }
  .prov-srclink:hover{color:#92400e;}
  /* small screen: popup이 화면 밖으로 안 나가도록 left 조정 */
  @media (max-width:600px){
    .provpop{right:auto;left:0;}
  }

  /* table */
  .tblpanel{margin-top:16px;padding:14px 16px;overflow:auto;}
  table.cmp{width:100%;border-collapse:collapse;font-size:13px;}
  table.cmp th,table.cmp td{text-align:right;padding:8px 10px;border-bottom:1px solid var(--line);
    white-space:nowrap;}
  table.cmp th:first-child,table.cmp td:first-child{text-align:left;}
  table.cmp thead th{font-size:11px;text-transform:uppercase;letter-spacing:.05em;color:var(--muted);}
  table.cmp .tname{font-weight:700;}
  table.cmp .dot{display:inline-block;width:9px;height:9px;border-radius:2px;margin-right:6px;}
  .yes{color:var(--good);font-weight:700;} .no{color:var(--bad);font-weight:700;}
  /* details */
  details.panel{margin-top:16px;padding:0;}
  details.panel>summary{cursor:pointer;padding:14px 16px;font-weight:700;font-size:13px;list-style:none;}
  details.panel>summary::-webkit-details-marker{display:none;}
  details.panel>summary::before{content:"▸ ";color:var(--muted);}
  details.panel[open]>summary::before{content:"▾ ";}
  .dbody{padding:0 16px 16px;}
  .atable{width:100%;border-collapse:collapse;font-size:12.5px;margin-top:8px;}
  .atable th,.atable td{padding:5px 6px;border-bottom:1px solid var(--line);text-align:center;}
  .atable th:first-child,.atable td:first-child{text-align:left;}
  .atable input{width:74px;padding:5px 6px;text-align:right;}
  .atable thead th{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;}
  .agrid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-top:6px;}
  .agrid label{font-size:12px;font-weight:600;color:#334155;}
  .agrid label small{display:block;font-weight:400;color:var(--muted);}
  .agrid input{width:100%;margin-top:3px;}
  .resetbtn{margin-top:12px;background:#f1f5f9;border:1px solid var(--line);border-radius:8px;
    padding:7px 14px;font:inherit;font-weight:600;cursor:pointer;}
  .resetbtn:hover{background:#e2e8f0;}
  .disclaim{font-size:12px;color:#475569;line-height:1.55;}
  .disclaim b{color:var(--ink);}
  footer{max-width:1480px;margin:8px auto 28px;padding:0 18px;color:var(--muted);font-size:11.5px;}
  .warnbox{background:#fffbeb;border:1px solid #fde68a;color:#92400e;border-radius:8px;
    padding:8px 11px;font-size:12px;margin-top:10px;}
  @media(max-width:1100px){
    .topgrid{grid-template-columns:1fr;}
    .controls{max-height:none;}
    .cards{grid-template-columns:repeat(2,1fr);}
    .agrid{grid-template-columns:repeat(2,1fr);}
  }
  @media(max-width:620px){.cards{grid-template-columns:1fr;}}
</style>
</head>
<body>
<header>
  <h1>On-Site Power Intelligence</h1>
  <div class="tag">The bottleneck for AI data centers isn't generating electricity — it's the grid delivering it. This tool estimates the fastest path to <b>behind-the-meter</b> power built next to the site, and shows the land it needs on a map.</div>
  <span class="badge">Planning estimates only — every number below is an editable assumption, not a vendor quote</span>
</header>

<div class="wrap">

  <!-- ============ SITEBAR (multi-site portfolio strip) ============ -->
  <div class="sitebar">
    <div class="sb-label">SITES</div>
    <div class="site-tabs" id="siteTabs"></div>
    <button id="newSiteBtn" class="sb-new" type="button">+ New site</button>
    <div class="sb-actions">
      <button id="renameBtn" class="sb-icon" type="button" title="Rename current site">Rename</button>
      <button id="deleteBtn" class="sb-icon" type="button" title="Delete current site">Delete</button>
      <button id="compareBtn" class="sb-cta" type="button">Compare all sites</button>
    </div>
  </div>

  <!-- ============ WORKBENCH (single-site analysis) ============ -->
  <div id="workbench">

  <div class="topgrid">
    <!-- ============ CONTROLS ============ -->
    <div class="panel controls">
      <div class="sec-title">1 · Site location</div>
      <div class="searchrow">
        <input type="text" id="addr" placeholder="Search an address or place…" />
        <button id="addrBtn" type="button">Find</button>
      </div>
      <div class="searchrow" style="margin-top:6px">
        <input type="text" id="coord" placeholder="Or paste coordinates:  41.3947, -87.9486" />
        <button id="coordBtn" type="button">Go</button>
      </div>
      <div class="latlng" id="latlng">Paste coordinates, search, click the map, or pick a hub below.</div>
      <div style="margin-top:8px" class="presets" id="presets"></div>
      <label class="fld" style="margin-top:10px"><span>Region / grid operator
        <small>auto-detected — editable</small></span>
        <select id="region"></select></label>

      <div class="sec-title">2 · Demand &amp; schedule</div>
      <label class="fld"><span>Target IT load <small>(MW, critical load)</small></span>
        <input type="number" id="itload" value="120" min="1" step="5" /></label>
      <div class="row2">
        <label class="fld"><span>Target online date</span>
          <input type="date" id="target" /></label>
        <label class="fld"><span>Available land <small>(acres)</small></span>
          <input type="number" id="land" value="60" min="0" step="5" /></label>
      </div>
      <div class="row2">
        <label class="fld"><span>Gas pipeline distance <small>(miles)</small></span>
          <input type="number" id="pipe" value="2" min="0" step="0.5" /></label>
        <label class="fld"><span>Grid queue wait <small>(months)</small></span>
          <input type="number" id="gridwait" value="60" min="0" step="6" /></label>
      </div>

      <div class="sec-title">3 · What matters most</div>
      <div class="seg" id="priority">
        <label><input type="radio" name="prio" value="speed" checked><span>Speed first</span></label>
        <label><input type="radio" name="prio" value="balanced"><span>Balanced</span></label>
        <label><input type="radio" name="prio" value="carbon"><span>Low carbon</span></label>
      </div>
      <div class="warnbox" id="inputwarn" style="display:none"></div>
      <div class="note" style="margin-top:14px">
        Today's date is used as the schedule baseline. Gas-fired options (turbine, reciprocating engine,
        fuel cell) need a pipeline tie-in; a long lateral adds time and cost. Solar is sized to actually
        firm a 24/7 load — which is why its land number is large and honest.
      </div>
    </div>

    <!-- ============ MAP ============ -->
    <div class="panel mapwrap">
      <div id="map"></div>
      <div class="maptools" id="maptools">
        <b>Map layers</b>
        <label><input type="checkbox" id="lyrTrans" checked> Transmission lines</label>
        <label><input type="checkbox" id="lyrSub" checked> Substations</label>
        <label><input type="checkbox" id="lyrPlant" checked> Power plants</label>
        <label><input type="checkbox" id="lyrPipe"> Gas pipelines</label>
        <label><input type="checkbox" id="gasring" checked> Gas tie-in ring</label>
        <div class="mt-status" id="layerStatus">Set a location to load nearby infrastructure.</div>
      </div>
      <div class="maplegend" id="maplegend"></div>
    </div>
  </div>

  <!-- ============ FOOTPRINT TO SCALE (collapsible) ============ -->
  <details class="panel fppanel">
    <summary>Land footprint — drawn to scale</summary>
    <div class="dbody">
      <div class="fpbody">
        <div id="fpDiagram"></div>
        <div class="fpside" id="fpSide"></div>
      </div>
    </div>
  </details>

  <!-- ============ REGIONAL CONTEXT ============ -->
  <!-- Print 전용 헤더 — 화면에서는 숨김, 인쇄 시 도구 이름·사이트·날짜 표시 -->
  <div class="printheader" id="workbenchPrintHeader"></div>

  <div class="regionctx" id="regionContext"></div>

  <!-- ============ VERDICT ============ -->
  <div class="verdict" id="verdict"></div>

  <!-- Print 버튼 — verdict 영역과 next steps 사이 -->
  <div class="printbar" id="printbar">
    <button type="button" class="printbtn" onclick="window.print()" title="PDF로 저장하거나 인쇄 (브라우저 인쇄 대화상자 → 'PDF로 저장' 선택)">
      📄 PDF로 저장 / 인쇄
    </button>
    <span class="printhint">위원회 deck · IC 메모 · CEO 슬라이드에 첨부용</span>
  </div>

  <!-- ============ NEXT STEPS — the actionable list ============ -->
  <div class="panel nextsteps" id="nextsteps"></div>

  <!-- ============ CARDS — 단일 4 시나리오 ============ -->
  <div class="cards" id="cards"></div>

  <!-- ============ HYBRID CARDS — 3 verified preset (Phase 1 MVP) ============ -->
  <div class="hybrid-section" id="hybridSection">
    <h3 class="hybrid-title">하이브리드 시나리오 — *verified deployment cases 기반*</h3>
    <p class="hybrid-sub">단일 발전원 외에 <b>2-3 발전원 mix</b>. Meta Socrates · Bloom AEP · Microsoft 패턴 같은 hyperscaler 표준 전략.
       위 단일 카드와 *같은 yardstick*으로 정규화 — 직접 비교.</p>
    <div class="cards hybrid-cards" id="hybridCards"></div>
  </div>

  <!-- ============ NUCLEAR PPA — 5번째 시나리오 (David 갭, 본 도구 BTM 범위 밖) ============ -->
  <div class="nuclear-ppa-section" id="nuclearPPASection">
    <h3 class="nuclear-ppa-title">⚛️ Off-site Nuclear PPA — *본 도구 BTM 범위 밖, 비교용*</h3>
    <p class="nuclear-ppa-sub">
      *24/7 carbon-free firm + GW급 부하*의 진짜 competitor. 3개 verified deals — Talen 2024-11 FERC 거부 후 *모든 nuclear-데이터센터 deals이 grid-connected FTM*.
      PE deal review · IC 메모 · CEO 슬라이드에서 *5번째 시나리오*로 비교 가능.
    </p>
    <div id="nuclearPPATable"></div>
    <p class="nuclear-ppa-foot">
      <b>의사결정 함의:</b> Carbon-free 24/7 + GW급 부하라면 *on-site BTM 4 시나리오*와 *off-site nuclear PPA*가 둘 다 검토 대상.
      BTM nuclear는 *FERC 2024-11 Talen 거부 후 사실상 막힘*.
    </p>
  </div>

  <!-- ============ TABLE ============ -->
  <div class="panel tblpanel">
    <div class="sec-title" style="margin-top:0">Side-by-side comparison</div>
    <table class="cmp" id="cmp"></table>
  </div>

  <!-- ============ ASSUMPTIONS ============ -->
  <details class="panel">
    <summary>Assumptions — edit any number to match your own data</summary>
    <div class="dbody" id="assumpBody"></div>
  </details>

  <!-- ============ METHOD / LIMITS ============ -->
  <details class="panel">
    <summary>How this works &amp; what it does not know</summary>
    <div class="dbody disclaim" id="methodBody"></div>
  </details>

  <!-- Print 전용 푸터 — 화면에서는 숨김, 인쇄 시 데이터 출처·dashboard URL 명시 -->
  <div class="printfooter" id="workbenchPrintFooter"></div>

  </div><!-- /#workbench -->

  <!-- ============ COMPARE VIEW (cross-site table) ============ -->
  <div class="panel compareview" id="compareView">
    <div class="printheader" id="comparePrintHeader"></div>
    <div class="cv-head">
      <div>
        <h2>Sites compared — same yardstick, all of them</h2>
        <div class="cv-sub">Click any row to open that site in the workbench.</div>
      </div>
      <div style="display:flex;gap:8px">
        <button type="button" class="printbtn" onclick="window.print()" title="PDF로 저장하거나 인쇄">
          📄 PDF로 저장
        </button>
        <button id="closeCompareBtn" class="sb-icon" type="button">← Back to workbench</button>
      </div>
    </div>
    <div id="cvBody"></div>
    <div class="printfooter" id="comparePrintFooter"></div>
  </div>

  <footer>
    On-Site Power Intelligence · A behind-the-meter feasibility estimator, not an engineering study.
    Map data & power infrastructure © OpenStreetMap contributors. Geocoding by Nominatim, infrastructure
    via the Overpass API.
  </footer>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<script>
"use strict";

/* ============================================================
   CONFIG — default assumptions (US market, 2025–2026 ranges)
   Every value is shown in the editable Assumptions panel.
   ============================================================ */
var TECH = {
  turbine:  {name:"Gas Turbine (simple-cycle)", short:"Gas Turbine", color:"#dc2626", fuel:"gas"},
  recip:    {name:"Reciprocating Gas Engines",  short:"Recip Engines", color:"#ea580c", fuel:"gas"},
  fuelcell: {name:"Solid-Oxide Fuel Cells",     short:"Fuel Cells",   color:"#7c3aed", fuel:"gas"},
  solar:    {name:"Solar PV + Battery (BESS)",  short:"Solar + BESS", color:"#16a34a", fuel:"none"}
};
var KEYS = ["turbine","recip","fuelcell","solar"];

/* PRESET_NUCLEAR_PPAS — 3 verified nuclear PPA deals (David 갭, 2026-05-29).
   본 도구 BTM 범위 밖이지만 *carbon-free 24/7 firm GW급 부하*의 진짜 competitor.
   별도 섹션에 항상 표시 — PE 투자자가 deal review 시 비교 옵션. */
var PRESET_NUCLEAR_PPAS = [
  {
    id: "ms-tmi-ccec",
    name: "Microsoft + Constellation TMI/CCEC",
    short: "MS-TMI",
    capacity_MW: 835,
    term_years: 20,
    online_year: 2028,
    structure: "Grid-connected FTM PPA (from start)",
    ISO: "PJM",
    state: "Pennsylvania",
    USD_billion: null,
    economic_signal: "3,400 jobs + $3B 세수 announce",
    significance: "Retired plant resurrection (2019 retire → 2028 restart)",
    ref_url: "https://www.sec.gov/Archives/edgar/data/0001868275/000186827524000058/ceg-202409208kexh991.htm"
  },
  {
    id: "vistra-comanche",
    name: "Vistra Comanche Peak",
    short: "Vistra-CP",
    capacity_MW: 1200,
    term_years: 20,
    extension_years: 20,
    online_year: 2027,
    full_ramp_year: 2032,
    structure: "Grid-connected FTM PPA",
    ISO: "ERCOT",
    state: "Texas",
    USD_billion: null,
    customer_disclosed: false,
    significance: "Existing plant reallocation, customer anonymous. Vistra Adjusted FCF 8-10% lift.",
    ref_url: "https://www.sec.gov/Archives/edgar/data/0001692819/000119312525221774/d43667d8k.htm"
  },
  {
    id: "talen-aws-restructured",
    name: "Talen-AWS Susquehanna (BTM failed → FTM)",
    short: "Talen-AWS",
    capacity_MW: 1920,
    term_years: 17,
    online_year: 2027,
    structure: "Grid-connected FTM PPA (restructured 2025-06)",
    ISO: "PJM",
    state: "Pennsylvania",
    USD_billion: 18,
    significance: "BTM 시도 → FERC 2024-11 거부 → FTM 전환. 미래 nuclear BTM 사실상 막힘.",
    ref_url: "https://www.sec.gov/Archives/edgar/data/0001622536/000162828025030559/a20250611pressreleasebusin.htm"
  }
];

/* PRESET_HYBRIDS — 3 verified hybrid 시나리오 (Phase 1 MVP, 2026-05-29).
   각 preset은 *실제 verified deployment case*에서 패턴 추출.
   단일 4 시나리오 (KEYS)에 추가로 표시 — 사용자가 같은 yardstick으로 비교. */
var PRESET_HYBRIDS = [
  {
    id: "fuel-cell-primary",
    name: "Fuel Cell + Solar (Bloom AEP 패턴)",
    short: "FC + Solar 80/20",
    color: "#5b21b6",  // 진한 보라
    description: "Fuel cell 80% (firm baseload) + Solar 20% (carbon offset). Bloom Energy AEP 1 GW announcement (2024-11) 같은 *대규모 carbon-free + reliability* 패턴.",
    mix: { fuelcell: 0.80, solar: 0.20 },
    ref_case: "Bloom Energy + AEP 1 GW (2024-11 발표)",
    ref_case_url: "https://investor.bloomenergy.com/press-releases/press-release-details/2024/Bloom-Energy-Announces-Gigawatt-Fuel-Cell-Procurement-Agreement-with-AEP-to-Power-AI-Data-Centers/default.aspx"
  },
  {
    id: "gas-mix",
    name: "Gas Turbine + Reciprocating (Meta Socrates 패턴)",
    short: "Gas mix 60/40",
    color: "#b91c1c",  // 진한 빨강
    description: "Gas turbine 60% (base) + Reciprocating 40% (quick-start). Meta Socrates Ohio 200 MW (2025-06 OPSB 승인) — 4 OEM mix의 *reliability + load-following* 조합.",
    mix: { turbine: 0.60, recip: 0.40 },
    ref_case: "Meta Socrates South Power Generation (Ohio, 200 MW × 2 sites)",
    ref_case_url: "https://www.power-eng.com/onsite-power/onsite-gas-turbines-reciprocating-engines-to-power-meta-data-center/"
  },
  {
    id: "carbon-free-hybrid",
    name: "Carbon-Free Hybrid (Microsoft 패턴)",
    short: "Carbon-free 60/40",
    color: "#15803d",  // 진한 녹색
    description: "Fuel cell 60% (firm clean) + Solar+BESS 40% (variable clean). Microsoft 40 GW PPA portfolio + on-site fuel cell 같은 *zero-carbon firm* 모델.",
    mix: { fuelcell: 0.60, solar: 0.40 },
    ref_case: "Microsoft 40 GW renewable portfolio (Brookfield $10B 10.5 GW + TMI/CCEC 835 MW)",
    ref_case_url: "https://carboncredits.com/microsoft-hits-100-renewable-electricity-milestone-with-40gw-clean-energy-portfolio/"
  }
];

/* DEFAULTS — 2026-05-29 권위 데이터 기반 업데이트.
   각 수치의 출처는 ASSUMPTION_PROVENANCE 객체 참조 (도구 하단 출처 패널 표시). */
var DEFAULTS = {
  pue:1.30, reserve:0.15, util:0.92,
  pipeCost:2.0,            // $M per mile of gas lateral
  solarCF:0.24,            // solar capacity factor (US tracking average)
  storageHrs:6,            // hours of battery storage — NREL Augustine & Blair 2021 SFS: BESS modeling capped at 10hr. 12hr는 modeled domain 밖. 6hr은 NREL 범위 내 + 현실적 hyperscaler peak-shaving 패턴 (2026-05-29 검증 변경 12→6)
  /* bessCost (이전 fixed $350/kWh, 12hr storageHrs 가정)는 *2가지 결함* —
     (1) Cole&Karmakar 2023 4hr 권위. 6hr·8hr·12hr 적용 시 정확도 떨어짐.
     (2) Cole·Ramasamy·Turan 2025 update에서 *2024 baseline이 30% 더 낮음* ($482→$334/kWh).
     2026-05-29 검증 후 split 공식으로 교체: energy_cost × duration + power_cost. */
  // lead time (months) — Wartsila Ohio 282 MW Q2'25 → 2026-2027 인도, Meta Socrates 200 MW 17개월 baseline
  // 2026-05-29 정직성 정정: fuelcell 12 → 18. 12mo는 Bloom 10-K Item 1 *가속 case* (Bloom 자체 "increasing number" 표현),
  // 18mo는 같은 10-K Item 1A Risk Factors *정상 sales cycle baseline*. 다른 verified deployment cases (Meta Socrates 17mo, Wartsila 18-21mo)와 align.
  lead:  {turbine:24, recip:18, fuelcell:18, solar:20},
  // capex ($/kW) — GridLab 2025-09 IRP/CPCN median, EIA Construction 2023 IC, Bloom 합성 추정, NREL ATB 2024 utility-scale PV
  capex: {turbine:1500, recip:1354, fuelcell:3800, solar:1300},
  // BESS energy cost ($/kWh) + power cost ($/kW) split — Cole, Ramasamy & Turan 2025 update (NREL/TP-6A40-93281).
  // Total: energy_cost × duration_hr + power_cost. 이전 fixed $350/kWh 단순 곱셈은 +15% 과대평가였음.
  bessEnergyCost: 241,  // $/kWh — battery pack 등 duration-scaled
  bessPowerCost: 372,   // $/kW — BOS·inverter·연결 fixed
  foot:  {turbine:0.04, recip:0.06, fuelcell:0.09, solar:6.5},  // acres per MW
  emis:  {turbine:0.55, recip:0.50, fuelcell:0.35, solar:0.0}   // tCO2 per MWh
};

