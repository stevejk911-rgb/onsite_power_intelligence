    short:"NoVA", iso:"PJM", utility:"Dominion Energy",
    lat:39.0, lng:-77.5, radiusKm:35,
    gridWaitMul:1.6, gasMilesAdd:4, capexMul:1.10,
    note:"Dominion 4,000 MW 데이터센터 부하 vs 2,100 MW 처리 가능 (2028). PJM queue 최대 15년. *Grid 의존 가장 불리한 시장 — BTM이 경쟁우위가 아닌 필수*."
  },
  { id:"columbus-franklin-licking", name:"Columbus Ohio (Franklin/Licking/Delaware)",
    short:"Columbus OH", iso:"PJM", utility:"AEP Ohio",
    lat:40.0, lng:-82.9, radiusKm:50,
    gridWaitMul:1.1, gasMilesAdd:-2, capexMul:1.0,
    note:"AEP Ohio 데이터센터 pipeline 30 GW → 13 GW (2025-07 PUCO tariff 도입). Marcellus·Utica 가스 풍부, *BTM에 가장 우호*. Meta Socrates + Wartsila 282 MW 거래 검증 사례."
  },
  { id:"silicon-valley-santa-clara", name:"Silicon Valley (Santa Clara/San Jose)",
    short:"Silicon Valley", iso:"CAISO", utility:"SVP + PG&E",
    lat:37.36, lng:-121.95, radiusKm:25,
    gridWaitMul:1.3, gasMilesAdd:0, capexMul:1.25,
    note:"California 환경 규제로 *gas turbine·reciprocating 사실상 불가*. Bloom SOFC가 default. FC NEM expired end-2023 — 신규 export 인센티브 없음.",
    techHardNo:["turbine","recip"]
  },
  { id:"dfw-dallas-tarrant", name:"Dallas-Fort Worth (Dallas/Tarrant/Collin)",
    short:"DFW", iso:"ERCOT", utility:"Oncor + AEP Texas",
    lat:32.78, lng:-96.80, radiusKm:50,
    gridWaitMul:0.7, gasMilesAdd:-2, capexMul:0.95,
    note:"ERCOT *energy-only* + 가스 매우 풍부 (Permian/Eagle Ford/Haynesville). 노조 약함. *BTM 가장 우호 (Columbus 다음)*. 2021 winter storm으로 hyperscaler grid 회피 강화."
  },
  { id:"phoenix-maricopa", name:"Phoenix metro (Maricopa)",
    short:"Phoenix", iso:"WALC", utility:"APS + SRP",
    lat:33.5, lng:-112.0, radiusKm:45,
    gridWaitMul:1.0, gasMilesAdd:2, capexMul:1.05,
    note:"Arizona 솔라 자원 강함 (GHI 1,850 kWh/m²/yr). *Solar+BESS이 매력적인 유일한 hot zone*. Microsoft·Google·Apple active. 가스 import 의존 단점."
  },
  /* ===== Round 2 (2026-05-29 추가) ===== */
  { id:"atlanta-south-douglas-coweta", name:"Atlanta South (Fulton·Douglas·Coweta)",
    short:"Atlanta", iso:"Southeast (SOCO)", utility:"Georgia Power",
    lat:33.49, lng:-84.75, radiusKm:50,
    gridWaitMul:1.4, gasMilesAdd:-2, capexMul:0.95,
    note:"*미국 #2 데이터센터 시장* (NoVA 다음). GA Power IT load 1.7→19.7 GW (4년 11.6x). 2025-12 GA PSC가 10 GW 신규 capacity 승인 (5 gas plants). South Atlanta 9.1 GW planned. Coweta County Project Sail 829-acre Prologis/Atlas."
  },
  { id:"reno-tahoe-storey", name:"Reno-Tahoe (Storey / TRIC)",
    short:"Reno-Tahoe", iso:"WECC (NV Energy)", utility:"NV Energy",
    lat:39.55, lng:-119.40, radiusKm:30,
    gridWaitMul:1.1, gasMilesAdd:2, capexMul:1.0,
    note:"*세계 5위 신흥 시장* (Cushman & Wakefield 2025). Switch Citadel 2,000 acres (Tahoe Reno 1 = 세계 최대 콜로 1.3M sqft). Apple·Google·Microsoft·Switch·Vantage 모두 active. *물 부족*이 cooling 제약."
  },
  { id:"hillsboro-silicon-forest", name:"Hillsboro Oregon (Silicon Forest)",
    short:"Hillsboro OR", iso:"WECC (PGE+BPA)", utility:"Portland General Electric",
    lat:45.52, lng:-122.99, radiusKm:25,
    gridWaitMul:0.8, gasMilesAdd:5, capexMul:1.10,
    note:"*Vacancy 0.2% — 미국 최저* (2025 H1). AWS 62 sites · Meta 10. PGE-Gridcare AI software로 *interconnection 가속* (80 MW pilot → 2029 400 MW). BPA hydro carbon-free 우위. Gas BTM은 Oregon DEQ permit 어려움. 2025 POWER Act (HB 3546)."
  },
  { id:"chicago-comed-ameren", name:"Chicago metro (ComEd PJM + Ameren MISO)",
    short:"Chicago", iso:"PJM/MISO split", utility:"ComEd (북) / Ameren (남)",
    lat:41.85, lng:-87.65, radiusKm:60,
    gridWaitMul:1.5, gasMilesAdd:0, capexMul:1.05,
    note:"ComEd *75+ apps / 28 GW backlog* (NoVA 4,000 MW의 7배). Joliet 795-acre IL 최대 데이터센터 승인. *ComEd shortfall 2029, Ameren 2031*. Midwest 가스 풍부. IL = 미국 #1 원전 주 (11 reactors) — 원전 PPA 옵션."
  },
  { id:"quincy-wa-grant-pud", name:"Quincy Washington (Grant County PUD)",
    short:"Quincy WA", iso:"WECC (BPA)", utility:"Grant County PUD (hydro)",
    lat:47.23, lng:-119.85, radiusKm:20,
    gridWaitMul:1.3, gasMilesAdd:8, capexMul:0.85,
    note:"*유일하게 BTM 불필요* — Wanapum + Priest Rapids dams 2,000+ MW hydro · 단가 *3¢/kWh* (미국 최저) · 100% carbon-free. Microsoft 21 buildings · Sabey generators 연 8시간만. 단 *2025 capacity maxed out* — 신규 wait 시작.",
    techHardNo:["turbine","recip"]
  }
];

var currentHotZone = null;  // 매칭된 hot zone (없으면 null)

/* Great-circle distance (km) — Haversine */
function haversineKm(lat1,lng1,lat2,lng2){
  var R=6371, toRad=function(d){return d*Math.PI/180;};
  var dLat=toRad(lat2-lat1), dLng=toRad(lng2-lng1);
  var a=Math.sin(dLat/2)*Math.sin(dLat/2) +
    Math.cos(toRad(lat1))*Math.cos(toRad(lat2))*Math.sin(dLng/2)*Math.sin(dLng/2);
  return 2*R*Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}

/* Find the closest hot zone within its radius. Returns null if none match. */
function matchHotZone(lat,lng){
  if(typeof lat !== "number" || typeof lng !== "number") return null;
  var best=null, bestD=Infinity;
  HOT_ZONES.forEach(function(z){
    var d=haversineKm(lat,lng,z.lat,z.lng);
    if(d <= z.radiusKm && d < bestD){ best=z; bestD=d; }
  });
  return best;
}

/* Apply a region: set the dropdown, auto-fill grid/gas inputs, render context.
   2026-05-29 update: hot zone 매칭 시 uplift factor를 default에 적용. */
function applyRegion(key,fillNumbers){
  currentRegion=key;
  $("region").value=key;
  // Hot zone 매칭은 현재 currentLat/currentLng이 set된 경우에만
  var zone = (typeof currentLat==="number" && typeof currentLng==="number")
    ? matchHotZone(currentLat, currentLng) : null;
  currentHotZone = zone;
  if(fillNumbers){
    var baseWait = REGIONS[key].gridWait;
    var baseGas  = REGIONS[key].gasMiles;
    if(zone){
      $("gridwait").value = Math.round(baseWait * zone.gridWaitMul);
      $("pipe").value     = Math.max(0, baseGas + zone.gasMilesAdd);
    } else {
      $("gridwait").value = baseWait;
      $("pipe").value     = baseGas;
    }
  }
  renderRegionContext(false);
  recompute();
}
function renderRegionContext(failed){
  var box=$("regionContext");
  if(failed){
    box.innerHTML='<div class="rk">Regional context</div>'+
      '<h3>'+(currentPlace||"Region not auto-detected")+'</h3>'+
      '<p>Could not map this location to a US grid region automatically — this tool covers the '+
      'US only. Pick a region from the dropdown on the left and the grid-queue and gas defaults '+
      'will auto-fill.</p>';
    return;
  }
  var R=REGIONS[currentRegion];
  var z=currentHotZone;  // 매칭된 hot zone (있으면 sub-region uplift 적용됨)
  var h='<div class="rk">Regional context'+
    (regionAuto?" — auto-detected from coordinates":" — selected manually")+'</div>';
  h+='<h3>'+(currentPlace||"Selected region")+'</h3>';
  h+='<p><b>'+R.label+'</b>'+ (z?' · <b style="color:#7c3aed">'+z.short+' hot zone</b>':'') +'</p>';
  var displayWait = z ? Math.round(R.gridWait * z.gridWaitMul) : R.gridWait;
  var displayGas  = z ? Math.max(0, R.gasMiles + z.gasMilesAdd) : R.gasMiles;
  h+='<div class="rgrid">'+
     rcell("Grid operator", (z?z.utility+' ('+z.iso+')' : R.iso))+
     rcell((z?"Sub-region grid queue":"Typical grid queue"), displayWait+" months"+
           (z && z.gridWaitMul!==1 ? ' <span style="color:#7c3aed;font-size:0.85em">('+(z.gridWaitMul>1?"+":"")+
           Math.round((z.gridWaitMul-1)*100)+"% vs "+R.iso+" baseline)</span>" : ""))+
     rcell("On-site gas access", R.gasRating + (z && z.gasMilesAdd ? ' <span style="color:#7c3aed;font-size:0.85em">('+(z.gasMilesAdd>0?"+":"")+z.gasMilesAdd+" mi vs baseline)</span>" : ""))+
     '</div>';
  h+='<p>'+R.note+'</p>';
  if(z){
    h+='<div style="background:#f3e8ff;border-left:3px solid #7c3aed;padding:0.7rem 0.9rem;margin:0.7rem 0;border-radius:4px">'+
       '<div style="font-weight:700;color:#581c87;margin-bottom:0.3rem">Sub-region overlay: '+z.name+'</div>'+
       '<p style="margin:0">'+z.note+'</p>'+
       (z.techHardNo && z.techHardNo.length ? '<p style="margin:0.5rem 0 0">⚠ <b>이 hot zone에서 비추천:</b> '+
         z.techHardNo.map(function(k){return TECH[k]?TECH[k].short:k;}).join(', ')+'</p>':'')+
       '<div style="font-size:0.85em;color:#581c87;margin-top:0.4rem">Capex 배수 '+z.capexMul+'× · 데이터 출처: <code>data/regions/data-center-hot-zones.json</code></div>'+
       '</div>';
  }
  h+='<p><b>Gas:</b> '+R.gas+'</p>';
  if(currentStateNote) h+='<p><b>Local note:</b> '+currentStateNote+'</p>';
  h+='<div class="src">Coarse ISO-level planning estimate'+(z?', refined by verified sub-region overlay':'')+
     '. The grid-queue wait ('+displayWait+' mo) and gas tie-in distance ('+displayGas+' mi) have been '+
     'auto-filled into the inputs above — replace them with real figures from the serving utility and '+
     'pipeline operator before relying on the result.</div>';
  if(solarInfo) h+='<div class="src" style="border-top:1px solid var(--line);margin-top:6px;'+
    'padding-top:6px">Site solar capacity factor: <b>'+solarInfo.cf.toFixed(2)+'</b> ('+solarInfo.src+
    ') — this has replaced the generic 0.24 default in the Solar + BESS estimate.</div>';
  box.innerHTML=h;
}
function rcell(l,n){return '<div class="rcell"><div class="l">'+l+'</div><div class="n">'+n+'</div></div>';}
function buildRegionSelect(){
  var h="";
  REGION_ORDER.forEach(function(k){
    h+='<option value="'+k+'">'+REGIONS[k].label+'</option>';
  });
  $("region").innerHTML=h;
}

/* ============================================================
   PRESETS + METHOD TEXT
   ============================================================ */
function buildPresets(){
  var box=$("presets");
  PRESETS.forEach(function(p){
    var b=document.createElement("button");
    b.type="button"; b.className="chip"; b.textContent=p.n;
    b.title="Set the site to "+p.n+" and auto-detect its grid region";
    b.addEventListener("click",function(){ setSite(p.lat,p.lng); });
    box.appendChild(b);
  });
}
function buildMethod(){
  $("methodBody").innerHTML=
    '<p><b>The idea.</b> An AI data center\'s real constraint is how fast it can secure electricity. '+
    'Generation is not the scarce thing — grid <i>delivery</i> is, because interconnection queues run '+
    '3–7 years in many US markets. When the queue is the bottleneck, the fastest electrons come from '+
    'generation built on the site itself, behind the meter. This tool ranks four on-site options on '+
    'speed, cost, land, and carbon.</p>'+
    '<p><b>How the math works.</b> Required capacity = IT load × PUE × (1 + reserve margin). '+
    'Gas-fired options add a pipeline-lateral penalty in time and cost when the tie-in is far. '+
    'Solar is deliberately sized to <i>firm</i> a round-the-clock load — nameplate = average load ÷ '+
    'capacity factor, plus battery storage — which is why its land and capex come out large. Each '+
    'option is scored relative to the others (fastest, cheapest, smallest, cleanest each earn 100 on '+
    'that metric); the weighting depends on the priority you choose. Land is treated as a hard '+
    'constraint — an option that does not fit cannot be recommended.</p>'+
    '<p><b>Regional auto-context.</b> When you set a location, the tool reverse-geocodes it to a US '+
    'state, maps that state to a grid region (PJM, ERCOT, MISO, CAISO, SPP, ISO-NE, NYISO, the '+
    'Southeast, or the non-RTO West), and auto-fills a region-typical grid-queue wait and gas tie-in '+
    'distance. Those defaults are coarse ISO-level estimates — a fast starting point, not measurements. '+
    'They drop straight into the editable inputs so you can replace them the moment you have real '+
    'utility and pipeline figures.</p>'+
    '<p><b>The map &amp; the footprint panel.</b> In a browser, the map shows real power infrastructure '+
    'near the site — transmission lines, substations, power plants and gas pipelines — pulled live '+
    'from OpenStreetMap via the Overpass API. That is community-mapped data: solid for US transmission '+
    'and substations, patchier for gas pipelines, and not survey-grade — an absent feature does not '+
    'prove nothing is there. The land footprints live in their own to-scale panel instead of on the '+
    'map, because area comparison and geography cannot share one map legibly.</p>'+
    '<p><b>What this is NOT.</b> It is a planning estimator, not an engineering study and not a vendor '+
    'quote. The defaults are mid-range US figures for 2025–2026 and they move constantly — turbine '+
    'backlogs, capex, and queue times in particular. <b>Treat every output as ±40% and verify with '+
    'OEMs, EPCs, and your utility before committing.</b></p>'+
    '<p><b>What it genuinely does not know.</b> It has no licensed capacity data — available transfer '+
    'capacity, a substation’s spare headroom, a pipeline’s deliverable volume and pressure — nor '+
    'parcel boundaries, zoning, air-permit limits, water access, or seismic and flood constraints. '+
    'Available land and IT load are <i>your</i> inputs; the gas distance and grid-queue wait are '+
    '<i>regional estimates</i>, not site measurements. The region mapping is coarse — a few states '+
    '(Illinois most notably) are split across two grid operators, and here Illinois is divided by '+
    'latitude only. It also assumes a single technology per scenario — in practice most fast-tracked '+
    'sites use a hybrid (fuel cells or turbines for firm power, solar to trim fuel cost and emissions) '+
    'and bridge with temporary rental gensets. Emissions shown are operational only and ignore '+
    'upstream methane and embodied carbon.</p>'+

    '<p><b>Data provenance (2026-05-29 권위 데이터 갱신).</b> 기본 capex·lead time 수치는 합성 추정이 '+
    '아닌 *실측 또는 권위 공시* 기반:</p>'+
    '<ul style="margin:0.5rem 0 0.5rem 1.5rem; line-height:1.55">'+
    '<li><b>가스터빈 capex $1,500/kW</b> — GridLab/EFG/Halcyon 2025-09 보고서 ('+
       '<a href="https://gridlab.org/wp-content/uploads/2025/09/GridLab_Gas-Turbine-Costs-Report-1.pdf" target="_blank" rel="noopener">PDF</a>'+
       '), state PSC IRP/CPCN filings 기반 simple cycle CT 2025-2029 median. '+
       'NREL ATB·EIA AEO 같은 공식 데이터는 *현재 시장 가격을 26-52% 과소평가* — 이 값을 권위 baseline으로 채택.</li>'+
    '<li><b>가스 reciprocating capex $1,354/kW</b> — EIA Construction Cost Data 2023 ('+
       '<a href="https://www.eia.gov/electricity/generatorcosts/" target="_blank" rel="noopener">link</a>'+
       '), Internal Combustion Engine 평균. 다중 OEM 시장이라 EIA가 공시 정상 수행.</li>'+
    '<li><b>Fuel cell capex $3,800/kW</b> — Bloom 10-K product gross margin + DOE H2/FC 목표 기반 *합성 추정*. '+
       'EIA는 Bloom 독점 구조로 공시 억제, NREL ATB는 SOFC 미추적 — *권위 단일 수치 부재가 구조적*. ±30% 범위로 취급.</li>'+
    '<li><b>Lead time</b> — Bloom 10-K FY2024 인용 ("less than twelve months"), Wartsila Ohio 282 MW Q2\'25→2026-2027 인도 (18-21mo), '+
       'GE Vernova FY2024 aero orders 44/sales 27 (공급 제약 신호). Meta Socrates 200 MW BTM는 17개월 baseline.</li>'+
    '<li><b>미국 fuel cell fleet 363.8 MW</b> — EIA-860 2024 ('+
       '<a href="https://www.eia.gov/electricity/data/eia860/" target="_blank" rel="noopener">EIA-860</a>'+
       ') ZIP 직접 다운로드 + Prime Mover=\'FC\' 필터. 186 generators. CA 42% + CT 28% + NY 16% = 86.5%.</li>'+
    '<li><b>미국 가스터빈(GT) fleet 158.6 GW</b> — EIA-860 2024 직접 추출. 2,333 units (디젤 460 제외). '+
       '*Aero <50 MW (데이터센터 BTM sweet spot): 21.5 GW (13.6%)*. Mid-frame 50-150 MW: 53.7%. Top operator TVA·Duke·FPL·Dominion = 모두 utility.</li>'+
    '<li><b>미국 가스 reciprocating(IC) fleet 7.9 GW</b> — *디젤 3,330 units 제외 가스만*. *Wartsila-class 15-25 MW: 2.0 GW (25.6%)*. 2024 신규 BOL 457 MW = 2021-2023 평균의 *2.7x* — 데이터센터 보급 가속 신호.</li>'+
    '<li><b>데이터센터 BTM은 *새 시장*</b> — 미국 가스 fleet 166 GW 중 BTM 적합 사이즈 (Aero GT + Wartsila-class IC + Fuel Cell) ≈ *24 GW = US fleet 2%*. Williams Companies·Meta·Crusoe 같은 BTM developer는 *EIA-860 2024에 아직 미반영* (2025-2027 BOL이라 다음 release에서 변화 예상).</li>'+
    '<li><b>비교 옵션: off-site nuclear PPA</b> *(우리 도구 범위 밖)* — 3개 verified GW급 deals: Microsoft TMI/CCEC 835 MW + Vistra Comanche Peak 1,200 MW + Talen-AWS 1,920 MW. *모두 grid-connected FTM PPA* — BTM nuclear는 FERC 2024-11 Talen 거부 후 *사실상 막힘*. 24/7 carbon-free firm 우선순위 + GW급 부하라면 본 도구의 4개 시나리오 외에 *원전 PPA*도 비교 가치.</li>'+
    '<li><b>검증된 케이스 스터디</b> — Meta Socrates South 200 MW BTM (Williams Companies + Sidecat/Meta, Ohio New Albany, OPSB 2025-06-09 승인): '+
       'Solar Turbines Titan 250 × 3 + PGM 130 × 9 + Siemens SGT400 × 3 + Cat 3520 × 15 = 4 OEM mix, 17개월 완공. *우리 도구의 사용 사례 그 자체*.</li>'+
    '</ul>'+
    '<p style="margin-top:0.5rem">전체 데이터 출처 + 신뢰도 등급 + 후속 작업 목록은 repo의 '+
       '<code>data/provenance.md</code>와 발전원별 JSON (<code>data/fuelcells/</code>, <code>data/gasturbines/</code>, '+
       '<code>data/deployment-cases/</code>)에 한 줄도 빠짐없이 기록되어 있음. '+
       '🟢 정부공공 / 🟡 기업 자체발표 / 🔴 유료·재배포 금지로 분류해 *법적 risk pre-screening*까지 완료.</p>'+
    '<p style="margin-top:0.8rem;padding:10px 14px;background:#f1f5f9;border-left:3px solid var(--amber);border-radius:4px">'+
       '📊 <b><a href="data-sources.html" style="color:#92400e">데이터 자산 dashboard 보기 →</a></b> &nbsp;'+
       '<span style="color:#475569;font-size:0.92em">우리 도구 뒤의 18+ verified source · 5 deployment cases · 10 hot zones · 5 구조적 발견을 한 페이지에서 스캔.</span></p>';
}

/* ============================================================
   APP STATE — multi-site portfolio backed by localStorage
   ============================================================ */
var STORAGE_KEY = "opi_sites_v1";
var appState = { currentId: null, sites: {} };

function escapeHtml(s){
  return String(s == null ? "" : s).replace(/[&<>"']/g, function(c){
    return ({"&":"&amp;","<":"&lt;",">":"&gt;","\"":"&quot;","'":"&#39;"})[c];
  });
}

function newSiteId(){ return "s_" + Math.random().toString(36).slice(2,10); }

function makeDefaultSite(id, name){
  return {
    id: id, name: name || "New site", createdAt: Date.now(),
    lat: 39.0438, lng: -77.4874,
    placeName: "Ashburn, Virginia (default)",
    regionKey: "PJM", regionAuto: true,
    stateNote: (typeof STATE_NOTES !== "undefined" ? (STATE_NOTES["virginia"] || "") : ""),
    itload: 120,
    target: fmtDate(addMonths(new Date(), 36)),
    land: 60, pipe: 3, gridwait: 60,
    priority: "speed",
    summary: ""
  };
}

function loadState(){
  try {
    var raw = localStorage.getItem(STORAGE_KEY);
    if(raw){
      var parsed = JSON.parse(raw);
      if(parsed && parsed.sites && Object.keys(parsed.sites).length){
        appState = parsed;
        if(!appState.sites[appState.currentId]){
          appState.currentId = Object.keys(appState.sites)[0];
        }
        return;
      }
    }
  } catch(e){ /* corrupted or unavailable — fall through */ }
  var id = newSiteId();
  appState = { currentId: id, sites: {} };
  appState.sites[id] = makeDefaultSite(id, "Site 1");
}

function saveState(){
  try { localStorage.setItem(STORAGE_KEY, JSON.stringify(appState)); } catch(e){}
}

function currentSite(){ return appState.sites[appState.currentId]; }

function persistCurrentSite(){
  var s = currentSite();
  if(!s) return;
  s.lat = siteLL.lat; s.lng = siteLL.lng;
  s.placeName = currentPlace;
  s.regionKey = currentRegion;
  s.regionAuto = !!regionAuto;
  s.stateNote = currentStateNote || "";
  s.itload = num("itload");
  s.target = $("target").value;
  s.land = num("land");
  s.pipe = num("pipe");
  s.gridwait = num("gridwait");
  var p = document.querySelector('input[name="prio"]:checked');
  s.priority = p ? p.value : "speed";
  s.summary = s.itload + " MW";
  saveState();
}

function loadSiteIntoForm(){
  var s = currentSite();
  if(!s) return;
  siteLL = { lat: s.lat, lng: s.lng };
  currentPlace = s.placeName || "";
  currentRegion = s.regionKey || "PJM";
  currentStateNote = s.stateNote || "";
  regionAuto = !!s.regionAuto;
  solarInfo = null;
  if(siteMarker) siteMarker.setLatLng([s.lat, s.lng]);
  $("itload").value = s.itload;
  $("target").value = s.target;
  $("land").value = s.land;
  $("pipe").value = s.pipe;
  $("gridwait").value = s.gridwait;
  var pi = document.querySelector('input[name="prio"][value="' + s.priority + '"]');
  if(pi) pi.checked = true;
  if($("region")) $("region").value = s.regionKey;
  updateLatLng();
  needRefit = true;
  renderRegionContext(false);
  recompute();
  fetchInfra(s.lat, s.lng);
  fetchSolar(s.lat, s.lng);
}

function switchSite(id){
  if(!appState.sites[id]) return;
  persistCurrentSite();
  appState.currentId = id;
  saveState();
  loadSiteIntoForm();
  renderSiteTabs();
}

function newSite(){
  persistCurrentSite();
  var id = newSiteId();
  var name = "Site " + (Object.keys(appState.sites).length + 1);
  appState.sites[id] = makeDefaultSite(id, name);
  appState.currentId = id;
  saveState();
  renderSiteTabs();
  loadSiteIntoForm();
}

function renameSite(){
  var s = currentSite();
  if(!s) return;
  var name = prompt("Site name:", s.name);
  if(name && name.trim()){
    s.name = name.trim().slice(0, 60);
    saveState();
    renderSiteTabs();
  }
}

function deleteSite(){
  if(Object.keys(appState.sites).length <= 1){
    alert("Cannot delete the only site — create another first.");
    return;
  }
  var s = currentSite();
  if(!s) return;
  if(!confirm('Delete "' + s.name + '"?')) return;
  delete appState.sites[appState.currentId];
  appState.currentId = Object.keys(appState.sites)[0];
  saveState();
  renderSiteTabs();
  loadSiteIntoForm();
}

function renderSiteTabs(){
  var box = $("siteTabs");
  if(!box) return;
  var ids = Object.keys(appState.sites);
  var html = "";
  ids.forEach(function(id){
    var s = appState.sites[id];
    var active = (id === appState.currentId);
    var sub = s.summary || (s.itload + " MW");
    html += '<button class="site-chip' + (active ? ' active' : '') + '" data-id="' + id + '" type="button">' +
      '<span class="site-chip-name">' + escapeHtml(s.name) + '</span>' +
      '<span class="site-chip-sub">' + escapeHtml(sub) + '</span>' +
      '</button>';
  });
  box.innerHTML = html;
  box.querySelectorAll(".site-chip").forEach(function(el){
    el.addEventListener("click", function(){ switchSite(el.dataset.id); });
  });
}

/* ============================================================
   COMPARE VIEW — cross-site table (same yardstick, all sites)
   ============================================================ */
function toggleCompare(force){
  var on;
  if(force === true) on = true;
  else if(force === false) on = false;
  else on = !document.body.classList.contains("mode-compare");
  document.body.classList.toggle("mode-compare", on);
  var btn = $("compareBtn");
  if(btn) btn.textContent = on ? "← Back to workbench" : "Compare all sites";
  if(on){
    persistCurrentSite();
    renderCompareTable();
  }
}

function computeForSite(siteId){
  var s = appState.sites[siteId];
  if(!s) return null;
  var save = {
    itload: $("itload").value,
    target: $("target").value,
    land: $("land").value,
    pipe: $("pipe").value,
    gridwait: $("gridwait").value,
    priority: (document.querySelector('input[name="prio"]:checked') || {}).value || "speed",
    hotZone: currentHotZone,        // hot zone state도 임시 저장
    lat: currentLat, lng: currentLng
  };
  $("itload").value = s.itload;
  $("target").value = s.target;
  $("land").value = s.land;
  $("pipe").value = s.pipe;
  $("gridwait").value = s.gridwait;
  // 사이트별 lat/lng로 hot zone 다시 매핑 — compute()가 currentHotZone을 참조하므로 필수
  currentLat = s.lat; currentLng = s.lng;
  currentHotZone = matchHotZone(s.lat, s.lng);
  var pi = document.querySelector('input[name="prio"][value="' + s.priority + '"]');
  if(pi) pi.checked = true;
  var D;
  try { D = compute(); } catch(e){ D = null; }
  $("itload").value = save.itload;
  $("target").value = save.target;
  $("land").value = save.land;
  $("pipe").value = save.pipe;
  $("gridwait").value = save.gridwait;
  currentHotZone = save.hotZone;    // hot zone state 복원
  currentLat = save.lat; currentLng = save.lng;
  pi = document.querySelector('input[name="prio"][value="' + save.priority + '"]');
  if(pi) pi.checked = true;
  return D;
}

function renderCompareTable(){
  var box = $("cvBody");
  if(!box) return;
  var ids = Object.keys(appState.sites);
  if(!ids.length){
    box.innerHTML = '<div class="cv-empty">No sites yet — add a site first.</div>';
    return;
  }
  var rows = ids.map(function(id){
    return { s: appState.sites[id], D: computeForSite(id) };
  });

  // 동일 결과 감지: site별 핵심 결과 시그니처가 모두 같으면 사용자에게 경고.
  // signature는 region + IT load + recommended tech + 반올림 lead time + 반올림 capex M.
  // 모든 site의 시그니처가 같으면 → 사용자가 입력 차이를 두지 않았거나 sub-region overlay가 안 잡힌 것.
  var bannerHtml = "";
  if(rows.length >= 2){
    var sigs = rows.map(function(r){
      if(!r.D || !r.D.rec) return null;
      var rec = r.D.rec, s = r.s;
      return [s.regionKey, s.itload, rec.key, Math.round(rec.leadTotal), Math.round(rec.capexM)].join("|");
    }).filter(Boolean);
    var allSame = sigs.length >= 2 && sigs.every(function(x){return x===sigs[0];});
    if(allSame){
      bannerHtml =
        '<div style="background:#fef3c7;border-left:4px solid #f59e0b;padding:0.8rem 1rem;margin:0 0 1rem 0;border-radius:6px">' +
        '<div style="font-weight:700;color:#78350f;margin-bottom:0.3rem">⚠ 모든 사이트가 동일한 결과를 내고 있어 — 입력이 같기 때문</div>' +
        '<p style="margin:0 0 0.4rem;color:#78350f;font-size:0.92em">' +
        '사이트들이 같은 region에 있고 IT load·land·gas distance·grid wait 모두 default 그대로일 가능성. ' +
        '실제 site는 *같은 PJM 안에서도 Loudoun VA(Dominion) vs Columbus OH(AEP)처럼 결과가 크게 달라야* 정상이야.</p>' +
        '<p style="margin:0;color:#78350f;font-size:0.92em"><b>해결법 3가지:</b> ' +
        '(1) 각 사이트의 위치가 *데이터센터 hot zone* 안에 있으면 자동 매핑됨 (NoVA·Columbus OH·DFW·Phoenix·Silicon Valley 현재 5곳 지원). ' +
        '범위 밖이면 매핑 안 됨 — workbench에서 좌표 다시 확인. ' +
        '(2) 각 사이트의 grid queue / gas distance / capex를 *실측 값*으로 직접 조정. ' +
        '(3) 사이트별 IT load·land 입력을 실제 값으로 분리.</p>' +
        '</div>';
    }
  }

  var html = bannerHtml + '<table class="cmpSites"><thead><tr>' +
    '<th>Site</th><th>Region</th><th>IT load</th><th>Recommended</th>' +
    '<th>Time</th><th>Capex</th><th>Land</th><th>Fits</th>' +
    '<th>CO₂ / yr</th><th>Score</th></tr></thead><tbody>';
  rows.forEach(function(r){
    if(!r.D || !r.D.rec) return;
    var s = r.s, rec = r.D.rec;
    var iso = (REGIONS[s.regionKey] || {}).iso || "—";
    // Hot zone 매칭 정보를 region 컬럼에 inline 표시 (compare view에서도 가시화)
    var zone = matchHotZone(s.lat, s.lng);
    var regionCell = iso + (zone ? '<br><small style="color:#7c3aed">'+zone.short+'</small>' : '');
    var placeLine = (s.placeName ? ' · ' + escapeHtml(s.placeName) : '');
    html += '<tr data-id="' + s.id + '">' +
      '<td class="sname">' + escapeHtml(s.name) +
        '<small>' + s.lat.toFixed(3) + ', ' + s.lng.toFixed(3) + placeLine + '</small></td>' +
      '<td>' + regionCell + '</td>' +
      '<td>' + s.itload + ' MW</td>' +
      '<td><span class="dot" style="background:' + rec.t.color + '"></span>' + rec.t.short + '</td>' +
      '<td>' + Math.round(rec.leadTotal) + ' mo</td>' +
      '<td>' + fmtMoney(rec.capexM) + '</td>' +
      '<td>' + fmtAcres(rec.landAcres) + '</td>' +
      '<td>' + (rec.landFit ? '<span class="yes">yes</span>' : '<span class="no">no</span>') + '</td>' +
      '<td>' + fmtCO2(rec.annualCO2) + '</td>' +
      '<td>' + Math.round(rec.score) + '</td>' +
      '</tr>';
  });
  html += '</tbody></table>';
  box.innerHTML = html;
  box.querySelectorAll("tbody tr").forEach(function(tr){
    tr.addEventListener("click", function(){
      var id = tr.dataset.id;
      toggleCompare(false);
      switchSite(id);
    });
  });
}

/* ============================================================
   INIT
   ============================================================ */
function init(){
  // default target = today + 36 months
  $("target").value=fmtDate(addMonths(new Date(),36));
  buildAssumptions();
  buildRegionSelect();
  buildPresets();
  buildMethod();
  initMap();

  ["itload","target","land","pipe","gridwait"].forEach(function(id){
    $(id).addEventListener("input",recompute);
  });
  document.querySelectorAll('input[name="prio"]').forEach(function(el){
    el.addEventListener("change",recompute);
  });
  ["lyrTrans","lyrSub","lyrPlant","lyrPipe"].forEach(function(id){
    $(id).addEventListener("change",applyLayerVisibility);
  });
  $("gasring").addEventListener("change",recompute);
  $("addrBtn").addEventListener("click",geocode);
  $("addr").addEventListener("keydown",function(e){ if(e.key==="Enter") geocode(); });
  $("coordBtn").addEventListener("click",gotoCoord);
  $("coord").addEventListener("keydown",function(e){ if(e.key==="Enter") gotoCoord(); });
  $("region").addEventListener("change",function(){
    regionAuto=false; applyRegion($("region").value,true);
  });

  // ---- Sitebar wiring (multi-site portfolio) ----
  $("newSiteBtn").addEventListener("click", newSite);
  $("renameBtn").addEventListener("click", renameSite);
  $("deleteBtn").addEventListener("click", deleteSite);
  $("compareBtn").addEventListener("click", function(){ toggleCompare(); });
  $("closeCompareBtn").addEventListener("click", function(){ toggleCompare(false); });

  // ---- Load saved sites (or create the default Ashburn site on first run) ----
  loadState();
  renderSiteTabs();
  loadSiteIntoForm();
}
document.addEventListener("DOMContentLoaded",init);
</script>
</body>
</html>
