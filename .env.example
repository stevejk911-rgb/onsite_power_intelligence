# Copy this file to ".env" and fill in values, OR set these as environment
# variables when you start the server. Nothing here is required to run — the
# app works with sensible defaults — but a real NREL key is recommended.

# NREL API key — powers the site-specific solar capacity factor (PVWatts).
# A free key takes about 30 seconds: https://developer.nrel.gov/signup/
# If left blank the app uses NREL's shared DEMO_KEY, which works but is
# heavily rate-limited and will fail under any real usage.
NREL_API_KEY=

# Port the server listens on (default 8080).
PORT=8080
